@model BiletSinema.Models.Tiyatrolar

@{
    ViewData["Title"] = "Tiyatro Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>➕ Tiyatro Ekle</h2>

<form method="post">

    <label>Tiyatro Adı</label>
    <input type="text" name="Adi" class="form-control mb-2" />

    <label>Tarih</label>
    <input type="date" name="Tarihi" class="form-control mb-2" />

    <label>Yazar Adı</label>
    <input type="text" name="YazarAdi" class="form-control mb-2" />

    <label>Süre</label>
    <input type="number" name="Sure" class="form-control mb-2" />

    <label>Puanı</label>
    <input type="number" step="0.1" name="Puan" class="form-control mb-2" />

    <label>Yorum</label>
    <textarea name="Yorum" class="form-control mb-2"></textarea>

    <label>Kategori</label>
    <select name="KategoriNo" class="form-control mb-3">
        <option value="">Kategori Seç</option>

        @foreach (var k in ViewBag.Kategoriler)
        {
            <option value="@k.KategoriNo">@k.KategoriAdi</option>
        }
    </select>

    <button class="btn btn-primary">Kaydet</button>
</form>