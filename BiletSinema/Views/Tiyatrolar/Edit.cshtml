@model BiletSinema.Models.Tiyatrolar

@{
    ViewData["Title"] = "Tiyatro Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>✏️ Tiyatro Güncelle</h2>

<form method="post">

    <input type="hidden" name="TiyatroNo" value="@Model.TiyatroNo" />

    <div class="mb-2">
        <label>Adı</label>
        <input type="text" name="Adi" value="@Model.Adi" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Tarih</label>
        <input type="date" name="Tarihi" value="@Model.Tarihi.ToString("yyyy-MM-dd")" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Yazar Adı</label>
        <input type="text" name="YazarAdi" value="@Model.YazarAdi" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Süre (dk)</label>
        <input type="number" name="Sure" value="@Model.Sure" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Puan</label>
        <input type="number" step="0.1" name="Puan" value="@Model.Puan" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Yorum</label>
        <textarea name="Yorum" class="form-control">@Model.Yorum</textarea>
    </div>

    <div class="mb-2">
        <label>Kategori</label>
        <select name="KategoriNo" class="form-control">

            @foreach (var k in ViewBag.Kategoriler)
            {
                if (k.KategoriNo == Model.KategoriNo)
                {
                    <option value="@k.KategoriNo" selected>
                        @k.KategoriAdi
                    </option>
                }
                else
                {
                    <option value="@k.KategoriNo">
                        @k.KategoriAdi
                    </option>
                }
            }

        </select>
    </div>

    <button type="submit" class="btn btn-success">Güncelle</button>

</form>