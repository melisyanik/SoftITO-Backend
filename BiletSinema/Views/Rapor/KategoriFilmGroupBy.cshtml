@model BiletSinema.ViewModels.RaporViewModel

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<h3>📊 Kategori İstatistik</h3>

<table class="table table-dark table-hover">
    <thead>
        <tr>
            <th>Kategori</th>
            <th>Film Sayısı</th>
            <th>Ortalama Puan</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.GroupRaporu)
        {
            <tr>
                <td>@item.KategoriAdi</td>
                <td>@item.FilmSayisi</td>
                <td>@item.OrtalamaPuan</td>
            </tr>
        }
    </tbody>
</table>