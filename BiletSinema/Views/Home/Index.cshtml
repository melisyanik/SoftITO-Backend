@model BiletSinema.Models.HomeViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <meta charset="utf-8" />
    <title>Kültür & Sinema Platformu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #0f0f0f;
            color: #f5f5f5;
            overflow-x: hidden;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background: #151515;
            border-bottom: 2px solid #b91c1c;
        }

        .navbar-brand {
            color: #dc2626 !important;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .btn-danger {
            background: #b91c1c;
            border: none;
            border-radius: 8px;
        }

        .hero {
            text-align: center;
            padding: 35px 0 15px 0;
        }

            .hero h1 {
                font-size: 3rem;
                font-weight: 700;
            }

            .hero p {
                color: #9ca3af;
            }

        .slider-container {
            position: relative;
            margin-top: 10px;
            padding: 0 55px;
        }

        .content-row {
            display: flex;
            gap: 22px;
            overflow-x: hidden;
            scroll-behavior: smooth;
            padding: 20px 0;
        }

        .card-item {
            min-width: 220px;
        }

            .card-item img {
                width: 220px;
                height: 330px;
                object-fit: cover;
                border-radius: 14px;
            }

        .title {
            text-align: center;
            margin-top: 10px;
        }

        .scroll-btn {
            position: absolute;
            top: 45%;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            border: none;
            background: #b91c1c;
            color: white;
        }

        .left {
            left: 0;
        }

        .right {
            right: 0;
        }

        .vizyon {
            margin: 50px 55px;
        }

            .vizyon h2 {
                border-left: 4px solid #dc2626;
                padding-left: 10px;
                margin-bottom: 20px;
            }

        .list-card {
            background: #1a1a1a;
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .list-card:hover {
                background: #222;
            }

        .badge-red {
            background: #dc2626;
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 12px;
        }

        .card-item {
            min-width: 220px;
            transition: all .35s ease;
            cursor: pointer;
        }

            .card-item img {
                width: 220px;
                height: 330px;
                object-fit: cover;
                border-radius: 14px;
                border: 2px solid transparent;
                transition: all .35s ease;
            }

            .card-item:hover {
                transform: scale(1.08);
            }

                .card-item:hover img {
                    border-color: #dc2626;
                    box-shadow: 0 0 12px rgba(220,38,38,.45), 0 0 30px rgba(220,38,38,.25), 0 10px 35px rgba(0,0,0,.55);
                }

        .netflix-navbar {
            position: sticky;
            top: 10px;
            z-index: 999;
            margin: 10px 20px;
            background: rgba(20, 20, 20, 0.92);
            backdrop-filter: blur(12px);
            border: 1px solid #2a2a2a;
            border-radius: 18px;
            padding: 12px 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.4);
        }

        .netflix-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
        }



        .netflix-left {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .netflix-logo {
            color: #e50914;
            font-weight: 800;
            letter-spacing: 2px;
            font-size: 22px;
            margin: 0;
        }

        .netflix-links a {
            color: #bbb;
            text-decoration: none;
            font-size: 14px;
            margin-right: 14px;
            transition: 0.2s;
        }

            .netflix-links a:hover {
                color: #fff;
            }


        .netflix-search-bar {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .netflix-search-bar input {
                width: 320px;
                padding: 8px 12px;
                border-radius: 12px;
                border: 1px solid #333;
                background: #1c1c1c;
                color: white;
                outline: none;
                transition: 0.3s;
            }

                .netflix-search-bar input:focus {
                    border-color: #e50914;
                    box-shadow: 0 0 8px rgba(229,9,20,0.4);
                }

            .netflix-search-bar button {
                background: #e50914;
                border: none;
                color: white;
                padding: 8px 14px;
                border-radius: 12px;
                cursor: pointer;
                transition: 0.2s;
            }

                .netflix-search-bar button:hover {
                    background: #b00610;
                }


        .netflix-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .netflix-profile span {
            width: 34px;
            height: 34px;
            background: #e50914;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: white;
            font-weight: bold;
        }

        .netflix-admin-btn {
            background: #e50914;
            color: white;
            padding: 7px 14px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            transition: 0.2s;
        }

            .netflix-admin-btn:hover {
                background: #b00610;
            }

 

        .netflix-links {
            display: none;
        }

        .netflix-navbar {
            padding: 10px 15px;
        }

        }</style>
</head>

<body>

    <header class="netflix-navbar">
        <div class="netflix-container">

            <div class="netflix-left">
                <h1 class="netflix-logo">STREAMFLIX</h1>

            </div>

            <div class="netflix-right">

                <div class="netflix-search-bar">
                    <input type="text" id="searchInput" placeholder="Film / Dizi / Tiyatro ara..." />
                    <button onclick="searchContent()">Ara</button>
                </div>

                <a href="/Rapor" class="netflix-admin-btn">
                    Admin Panel
                </a>

            </div>

        </div>
    </header>

    <div class="hero">
        <h1>Kültür ve Sanatın Dijital Sahnesi</h1>
        <p>Filmler, diziler ve tiyatro oyunlarını keşfedin</p>
    </div>

    <h3 class="ms-5">🎬 Öne Çıkanlar</h3>

    <div class="slider-container">

        <button class="scroll-btn left" onclick="scrollLeftFunc()">❮</button>

        <div class="content-row" id="contentRow">

            <div class="card-item">
                <img src="https://image.tmdb.org/t/p/w500/gEU2QniE6E77NI6lCU6MxlNBvIx.jpg">
                <div class="title">Interstellar (Film)</div>
            </div>

            <div class="card-item">
                <img src="https://image.tmdb.org/t/p/w500/qJ2tW6WMUDux911r6m7haRef0WH.jpg">
                <div class="title">The Dark Knight (Film)</div>
            </div>

            <div class="card-item">
                <img src="https://image.tmdb.org/t/p/w500/8UlWHLMpgZm9bx6QYh0NFoq67TZ.jpg">
                <div class="title">Wonder Woman (Film)</div>
            </div>

            <div class="card-item">
                <img src="https://image.tmdb.org/t/p/w500/7WsyChQLEftFiDOVTGkv3hFpyyt.jpg">
                <div class="title">Avengers: Endgame (Film)</div>
            </div>

            <div class="card-item">
                <img src="https://image.tmdb.org/t/p/w500/6CoRTJTmijhBLJTUNoVSUNxZMEI.jpg">
                <div class="title">Breaking Bad (Dizi)</div>
            </div>

            <div class="card-item">
                <img src="https://picsum.photos/220/330?random=101">
                <div class="title">Peaky Blinders (Dizi)</div>
            </div>

            <div class="card-item">
                <img src="https://picsum.photos/220/330?random=102">
                <div class="title">Hamlet (Tiyatro)</div>
            </div>

        </div>

        <button class="scroll-btn right" onclick="scrollRightFunc()">❯</button>

    </div>

    <div class="vizyon">

        <h2>🎬 Vizyondaki Filmler</h2>

        @foreach (var item in Model.Filmler)
        {
            <div class="list-card">
                <div>
                    <b>@item.Adi</b><br />
                    <small>@item.kategori?.KategoriAdi</small>
                </div>

                <div>
                   IMDB ⭐ @item.Puan
                </div>
            </div>
        }

    </div>

    <div class="vizyon">

        <h2>📺 Vizyondaki Diziler</h2>

        @foreach (var item in Model.Diziler)
        {
            <div class="list-card">
                <div>
                    <b>@item.Adi</b><br />
                    <small>@item.BolumSayisi bölüm</small>
                </div>

                <div>
                   IMDB ⭐ @item.Puan
                </div>
            </div>
        }

    </div>

    <div class="vizyon">

        <h2>🎭 Vizyondaki Tiyatrolar</h2>

        @foreach (var item in Model.Tiyatrolar)
        {
            <div class="list-card">
                <div>
                    <b>@item.Adi</b><br />
                    <small>@item.YazarAdi</small>
                </div>

                <div>
                   IMDB ⭐ @item.Puan
                </div>
            </div>
        }

    </div>


    <script>

        function scrollRightFunc() {
            document.getElementById("contentRow")
                .scrollBy({ left: 800, behavior: "smooth" });
        }

        function scrollLeftFunc() {
            document.getElementById("contentRow")
                .scrollBy({ left: -800, behavior: "smooth" });
        }

                  function searchContent() {
            let input = document.getElementById("searchInput").value.toLowerCase().trim();

            let sections = document.querySelectorAll(".slider-container, .vizyon");

            sections.forEach(section => {

                let items = section.querySelectorAll(".card-item, .list-card");

                let hasMatch = false;

                items.forEach(item => {

                    let text = item.innerText.toLowerCase();

                    if (input === "" || text.includes(input)) {
                        item.style.display = "";
                        hasMatch = true;
                    } else {
                        item.style.display = "none";
                    }
                });

             
                if (input === "") {
                    section.style.display = "";
                }
                else {
                    section.style.display = hasMatch ? "" : "none";
                }
            });
        }

                document.addEventListener("DOMContentLoaded", function () {

            const input = document.getElementById("searchInput");

            input.addEventListener("keypress", function (e) {
                if (e.key === "Enter") {
                    searchContent();
                }
            });

        });

    </script>

</body>
</html>