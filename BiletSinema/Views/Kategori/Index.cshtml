@model List<BiletSinema.Models.Kategori>

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>🏷️ Kategoriler</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Yeni Kategori</a>
<form method="get" class="mb-3">

    <div class="row">

     
        <div class="col-md-4">
            <select name="filterType" class="form-control">
                <option value="KategoriNo">Kategori No</option>
                <option value="KategoriAdi">Kategori Adı</option>
            </select>
        </div>

      
        <div class="col-md-6">
            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Kategori ara..." />
        </div>

     
        <div class="col-md-2">
            <button class="btn btn-primary w-100">
                🔍 Ara
            </button>
        </div>

    </div>

</form>

<div class="mb-3">
    <a asp-action="ExportToPdf" class="btn btn-danger">
        📄 PDF İndir
    </a>

    <a asp-action="ExportToExcel" class="btn btn-success">
        📊 Excel İndir
    </a>
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Kategori No</th>
            <th>Kategori Adı</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.KategoriNo</td>
                <td>@item.KategoriAdi</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.KategoriNo" class="btn btn-success btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.KategoriNo" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>