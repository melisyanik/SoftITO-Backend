@model List<BiletSinema.Models.Filmler>

@{
    ViewData["Title"] = "Filmler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>🎬 Filmler</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Yeni Film Ekle</a>

<form method="get" class="mb-3">

    <div class="row">

        <div class="col-md-3">
            <select name="filterType" class="form-control">

                <option value="FilmNo">Film No</option>

                <option value="Adi">Film Adı</option>

                <option value="Tarihi">Tarih</option>

                <option value="Yorum">Yorum</option>

                <option value="KategoriNo">Kategori No</option>

                <option value="Kategori">Kategori</option>

            </select>
        </div>

        <div class="col-md-6">
            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Aranacak değeri giriniz..." />
        </div>

        <div class="col-md-3">
            <button class="btn btn-primary w-100">
                🔍 Ara
            </button>
        </div>

    </div>

</form>

<div class="mb-3">
    <a asp-action="ExportToPdf" class="btn btn-danger">
        📄 PDF İndir
    </a>

    <a asp-action="ExportToExcel" class="btn btn-success">
        📊 Excel İndir
    </a>
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Film No</th>
            <th>Adı</th>
            <th>Tarih</th>
            <th>Puan</th>
            <th>Yorum</th>
            <th>Kategori No</th>
            <th>Kategori</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FilmNo</td>
                <td>@item.Adi</td>
                <td>@item.Tarihi.ToShortDateString()</td>
                <td>@item.Puan</td>
                <td>@item.Yorum</td>
                <td>@item.kategori?.KategoriNo</td>
                <td>@item.kategori?.KategoriAdi</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.FilmNo" class="btn btn-success btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.FilmNo" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>