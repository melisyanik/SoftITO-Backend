@using BelediyeSikayet.Models.ViewModel
@using System.Text.Json

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var list = ViewBag.Data as List<RaporViewModel>;

    var ilceData = ViewBag.IlceChart as List<RaporViewModel>;
    var durumData = ViewBag.DurumChart as List<RaporViewModel>;
}

<h2>📊 Rapor Paneli</h2>


<form method="get" class="mb-3">
    <select name="raporId" class="form-control" onchange="this.form.submit()">
        <option value="1" selected="@(ViewBag.RaporId == 1)">Cevaplanmamış</option>
        <option value="2" selected="@(ViewBag.RaporId == 2)">İlçe Dağılımı</option>
        <option value="3" selected="@(ViewBag.RaporId == 3)">Kategori Dağılımı</option>
        <option value="4" selected="@(ViewBag.RaporId == 4)">Durum Dağılımı</option>
        <option value="5" selected="@(ViewBag.RaporId == 5)">En Çok Cevaplanan İlçe</option>
    </select>
</form>

<div class="mb-3">
    <a href="/Rapor/ExportPdf?raporId=@ViewBag.RaporId"
       class="btn btn-danger">
        📄 PDF İndir
    </a>

    <a href="/Rapor/ExportExcel?raporId=@ViewBag.RaporId"
       class="btn btn-success">
        📊 Excel İndir
    </a>
</div>

<hr />


@if (list != null && list.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Bilgi</th>
                <th>Detay</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in list)
        {
            <tr>
                <td>@(item.Baslik ?? item.AdSoyad ?? item.Ilce ?? "-")</td>
                <td>@item.Sayi</td>
            </tr>
        }
        </tbody>
    </table>
}

<hr />


<div class="row">
    <div class="col-md-6">
        <h4>İlçe Dağılımı</h4>
        <canvas id="ilceChart"></canvas>
    </div>

    <div class="col-md-6">
        <h4>Durum Dağılımı</h4>
        <canvas id="durumChart"></canvas>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ilceData = @Html.Raw(JsonSerializer.Serialize(ilceData));
    const durumData = @Html.Raw(JsonSerializer.Serialize(durumData));

   

    new Chart(document.getElementById('ilceChart'), {
        type: 'bar',
        data: {
            labels: ilceData.map(x => x.AdSoyad),
            datasets: [{
                label: 'Şikayet Sayısı',
                data: ilceData.map(x => x.Sayi),
                backgroundColor: '#4e73df'
            }]
        },
        options: {
            responsive: true
        }
    });

  
    new Chart(document.getElementById('durumChart'), {
        type: 'pie',
        data: {
            labels: durumData.map(x => x.AdSoyad),
            datasets: [{
                data: durumData.map(x => x.Sayi),
                backgroundColor: ['orange', 'green', 'blue']
            }]
        },
        options: {
            responsive: true
        }
    });
</script>