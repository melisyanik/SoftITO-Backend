@model List<BelediyeSikayet.Models.Kategori>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>📂 Kategoriler</h3>

<form method="get" class="row mb-3">
    <div class="col-md-4">
        <select name="field" class="form-control">
            <option value="">Arama Türü Seç</option>
            <option value="id">ID</option>
            <option value="ad">Kategori Adı</option>
        </select>
    </div>

    <div class="col-md-6">
        <input type="text" name="value" class="form-control" placeholder="Arama değeri..." />
    </div>

    <div class="col-md-2">
        <button class="btn btn-success w-100">Ara</button>
    </div>
</form>

<div class="mb-3">
    <a href="/Kategori/ExportPdf" class="btn btn-danger">PDF İndir</a>
    <a href="/Kategori/ExportExcel" class="btn btn-success">Excel İndir</a>
</div>

<a href="/Kategori/Create" class="btn btn-primary mb-3">
    ➕ Yeni Kategori
</a>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Kategori Adı</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.KategoriId</td>
                <td>@item.Ad</td>
                <td>
                    <a href="/Kategori/Update/@item.KategoriId" class="btn btn-warning btn-sm">
                        Düzenle
                    </a>

                    <a href="/Kategori/Delete/@item.KategoriId" class="btn btn-danger btn-sm"
                       onclick="return confirm('Silmek istiyor musun?');">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>