<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            background: #f4f7f4;
            overflow-x: hidden;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: linear-gradient(180deg, #1f6f3d, #14532d);
            color: white;
            padding-top: 20px;
            transition: all 0.35s ease;
            overflow: hidden;
        }

          
            .sidebar.closed {
                width: 70px;
            }

           
            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                color: white;
                text-decoration: none;
                white-space: nowrap;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.15);
                }

           
            .sidebar .icon {
                width: 25px;
                text-align: center;
                font-size: 18px;
            }

            .sidebar .text {
                transition: opacity 0.2s ease;
            }

            .sidebar.closed .text {
                display: none;
            }

        .content {
            margin-left: 240px;
            padding: 20px;
            transition: all 0.35s ease;
        }

        
        .sidebar.closed ~ .content {
            margin-left: 70px;
        }

        .menu-toggle {
            position: fixed;
            top: 15px;
            left: 15px;
            width: 45px;
            height: 45px;
            border-radius: 10px;
            border: none;
            background: #1f6f3d;
            color: white;
            font-size: 20px;
            z-index: 999;
            transition: 0.3s;
        }

            .menu-toggle:hover {
                transform: scale(1.05);
            }

        .card {
            transition: 0.2s;
        }

            .card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 18px rgba(0,0,0,0.15);
            }

    </style>

</head>

<body>

    <button class="menu-toggle" onclick="toggleMenu()">☰</button>

    <div class="sidebar" id="sidebar">

        <h5 class="text-center">Admin Panel</h5>

        <a href="/Admin/Index">
            <span class="icon">📊</span>
            <span class="text">Anasayfa</span>
        </a>

        <a href="/Sikayetler/Index">
            <span class="icon">📩</span>
            <span class="text">Şikayetler</span>
        </a>

        <a href="/Kategori/Index">
            <span class="icon">📂</span>
            <span class="text">Kategoriler</span>
        </a>

        <a href="/Cevap/Index">
            <span class="icon">💬</span>
            <span class="text">Cevaplar</span>
        </a>

        <a href="/Rapor/Index">
            <span class="icon">📈</span>
            <span class="text">İstatistikler</span>
        </a>

        <a href="/Admin/Users">
            <span class="icon">👥</span>
            <span class="text">Kullanıcılar</span>
        </a>

        <a href="/Admin/Logout">
            <span class="icon">⬅</span>
            <span class="text">Çıkış Yap</span>
        </a>

    </div>

    <div class="content">
        @RenderBody()
    </div>

    <script>
        function toggleMenu() {
            document.getElementById("sidebar").classList.toggle("closed");
        }
    </script>

</body>
</html>