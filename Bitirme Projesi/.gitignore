## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
[Releases]/
x64/
x86/
build/
bld/
[Bin]/
[Ob]ject/
[Obj]/

# MSTest test Results
[T]est[R]esult*/
[B]uild[L]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build Performance Diagnostics
*.psess
*.vsp
*.vspx
*.sap

# Large Folder ignore
.vs/
.vscode/
bin/
obj/
Logs/

# Database files
*.mdf
*.ldf
*.ndf

# Local settings
appsettings.json
appsettings.Development.json
!SmartMunicipality/appsettings.json
!SmartMunicipality/appsettings.Development.json
!SmartMunicipality.EFCoreApi/appsettings.json
!SmartMunicipality.EFCoreApi/appsettings.Development.json
