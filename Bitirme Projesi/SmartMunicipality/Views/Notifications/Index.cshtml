@model IEnumerable<SmartMunicipality.MODEL.Notification>
@{
    ViewData["Title"] = "Tüm Bildirimler";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-bell"></i>
        </span> Bildirimlerim
    </h3>
</div>

<div class="row">
    <div class="col-md-8 mx-auto grid-margin stretch-card">
        <div class="card" style="border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: none;">
            <div class="card-body p-5">
                <h4 class="card-title mb-4">Tüm Bildirimleriniz</h4>
                
                @if (Model != null && Model.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var notif in Model.OrderByDescending(n => n.CreatedDate))
                        {
                            <div class="list-group-item list-group-item-action d-flex align-items-start py-3 @(notif.IsRead ? "" : "bg-light")" style="border-radius: 12px; margin-bottom: 0.5rem; border: none;">
                                <div class="me-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white" 
                                         style="width: 45px; height: 45px; background: @(notif.NotificationType == "Bill" ? "var(--color-secondary)" : (notif.NotificationType == "Alert" ? "#ff4d4d" : "var(--color-primary)"))">
                                        <i class="mdi @(notif.NotificationType == "Bill" ? "mdi-receipt" : (notif.NotificationType == "Alert" ? "mdi-alert-decagram-outline" : "mdi-check")) fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                        <h5 class="mb-0 fw-bold @(notif.IsRead ? "text-secondary" : "text-dark")" style="font-size: 1rem;">@notif.Title</h5>
                                        <small class="text-muted">@notif.CreatedDate.ToString("dd MMM yyyy HH:mm")</small>
                                    </div>
                                    <p class="mb-0 text-muted" style="font-size: 0.9rem; line-height: 1.5;">@notif.Message</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="mdi mdi-bell-sleep-outline text-muted" style="font-size: 4rem;"></i>
                        <p class="text-muted mt-3">Herhangi bir bildirim bulunmuyor.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
