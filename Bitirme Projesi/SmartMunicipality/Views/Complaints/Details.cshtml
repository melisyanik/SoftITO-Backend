@model SmartMunicipality.MODEL.Complaint
@{
    ViewData["Title"] = "Şikayet Detayı";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-information-outline"></i>
        </span> Şikayet Detayı
    </h3>
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Şikayetler</a></li>
            <li class="breadcrumb-item active" aria-current="page">Detay</li>
        </ul>
    </nav>
</div>

<div class="row">
    <!-- Sol Taraf: Şikayet Bilgileri -->
    <div class="col-md-7 grid-margin stretch-card">
        <div class="card" style="border-radius: 20px; border: none; box-shadow: 0 10px 20px rgba(0,0,0,0.03);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-dark fw-bold mb-0">@Model.Title</h3>
                    <div>
                        @if(Model.StatusId == 1) { <span class="badge badge-warning fs-6">Beklemede</span> }
                        else if(Model.StatusId == 2) { <span class="badge badge-info fs-6">İnceleniyor</span> }
                        else if(Model.StatusId == 3) { <span class="badge badge-success fs-6">Çözüldü</span> }
                        else if(Model.StatusId == 4) { <span class="badge badge-danger fs-6">Reddedildi</span> }
                        else { <span class="badge badge-secondary fs-6">Bilinmiyor</span> }
                    </div>
                </div>

                <div class="mb-3">
                    <span class="text-muted"><i class="mdi mdi-calendar"></i> Bildirim Tarihi:</span>
                    <strong class="text-dark">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</strong>
                </div>

                <div class="mb-3">
                    <span class="text-muted"><i class="mdi mdi-tag-outline"></i> Kategori:</span>
                    <strong class="text-dark">@(Model.Category?.Name ?? "Genel")</strong>
                </div>

                <div class="mb-3">
                    <span class="text-muted"><i class="mdi mdi-map-marker"></i> Adres (İlçe):</span>
                    <strong class="text-dark">@Model.Address</strong>
                </div>

                <div class="mb-3">
                    <span class="text-muted"><i class="mdi mdi-phone"></i> Telefon:</span>
                    <strong class="text-dark">@Model.Phone</strong>
                </div>

                <hr>

                <div class="mt-4">
                    <h5 class="fw-bold text-dark">Açıklama</h5>
                    <p class="text-muted" style="line-height: 1.6; white-space: pre-line;">@Model.Description</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ Taraf: Harita Konumu -->
    <div class="col-md-5 grid-margin stretch-card">
        <div class="card" style="border-radius: 20px; border: none; box-shadow: 0 10px 20px rgba(0,0,0,0.03);">
            <div class="card-body">
                <h4 class="card-title"><i class="mdi mdi-map-outline"></i> Bildirilen Konum</h4>
                @if (Model.Latitude != 0 && Model.Longitude != 0)
                {
                    <div id="detailMap" style="height: 300px; border-radius: 12px;" class="mt-3"></div>
                }
                else
                {
                    <div class="alert alert-light text-center mt-3">Bu şikayet için harita konumu işaretlenmemiş.</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Yanıtlar / Cevaplar Section -->
<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card" style="border-radius: 20px; border: none; box-shadow: 0 10px 20px rgba(0,0,0,0.03);">
            <div class="card-body">
                <h4 class="card-title"><i class="mdi mdi-comment-multiple-outline"></i> Belediye Çözüm Yanıtları</h4>
                
                <div class="mt-4">
                    @if (Model.Responses != null && Model.Responses.Any())
                    {
                        foreach (var resp in Model.Responses.OrderBy(r => r.CreatedDate))
                        {
                            <div class="p-4 mb-3 border" style="border-radius: 15px; background-color: #fafafa;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <strong class="text-primary"><i class="mdi mdi-account-star"></i> Belediye Yetkilisi</strong>
                                        <span class="text-muted" style="font-size: 0.8rem; margin-left: 10px;">@resp.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                                <p class="mb-0 text-dark" style="line-height: 1.5;">@resp.ResponseText</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-light text-center py-4">
                            <i class="mdi mdi-information-outline fs-3 text-muted"></i>
                            <p class="mb-0 text-muted mt-2">Şikayetiniz henüz incelenme aşamasında. Belediye ekiplerimiz inceleme yaptığında buraya yanıt eklenecektir.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (Model.Latitude != 0 && Model.Longitude != 0)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var title = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Title ?? "Şikayet"));
                
                var map = L.map('detailMap', { zoomControl: false }).setView([lat, lng], 14);
                L.control.zoom({ position: 'bottomright' }).addTo(map);

                L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; OpenStreetMap &copy; CARTO',
                    maxZoom: 19
                }).addTo(map);

                L.marker([lat, lng]).addTo(map)
                    .bindPopup('<b>Şikayet Konumu</b><br>' + title)
                    .openPopup();
            });
        </script>
    }
}
