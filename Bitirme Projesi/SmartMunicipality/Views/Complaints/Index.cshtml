@model IEnumerable<SmartMunicipality.Models.ComplaintViewModel>

@{
    ViewData["Title"] = "Şikayetler";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-format-list-bulleted"></i>
        </span> Belediye Şikayet ve Talepleri
    </h3>
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">
                <a asp-action="Create" class="btn btn-gradient-info btn-fw">Yeni Şikayet Oluştur</a>
            </li>
        </ul>
    </nav>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success shadow-sm">
        @TempData["Message"]
    </div>
}

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Kayıtlı Şikayetler</h4>
                
                <div class="mb-4 d-flex gap-2 flex-wrap">
                    <div class="input-group" style="max-width: 350px;">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px; border-color: rgba(0, 103, 105, 0.15);">
                            <i class="mdi mdi-magnify text-muted"></i>
                        </span>
                        <input type="text" id="complaintSearchInput" class="form-control border-start-0" style="border-radius: 0; border-color: rgba(0, 103, 105, 0.15); padding: 0.75rem;" placeholder="Aramak istediğiniz terimi girin..." />
                    </div>
                    <select id="complaintFieldSelect" class="form-select" style="max-width: 180px; border-radius: 12px; border-color: rgba(0, 103, 105, 0.15); padding: 0.75rem;">
                        <option value="all">Tüm Alanlar</option>
                        <option value="1">Başlık</option>
                        <option value="2">Adres</option>
                        <option value="3">Durum</option>
                    </select>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Başlık</th>
                                <th>Adres</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model.OrderByDescending(x => x.CreatedDate))
                                {
                                    <tr>
                                        <td>@item.CreatedDate.ToShortDateString()</td>
                                        <td class="font-weight-bold">@item.Title</td>
                                        <td>@item.Address</td>
                                        <td>
                                            @if(item.StatusId == 1) { <label class="badge badge-warning">Beklemede</label> }
                                            else if(item.StatusId == 2) { <label class="badge badge-info">İnceleniyor</label> }
                                            else if(item.StatusId == 3) { <label class="badge badge-success">Çözüldü</label> }
                                            else if(item.StatusId == 4) { <label class="badge badge-danger">Reddedildi</label> }
                                            else { <label class="badge badge-secondary">Bilinmiyor</label> }
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-gradient-primary">Detay</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        Henüz hiçbir şikayet kaydı bulunmuyor.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var searchInput = document.getElementById('complaintSearchInput');
            var fieldSelect = document.getElementById('complaintFieldSelect');
            
            function filterComplaints() {
                var query = searchInput.value.toLowerCase().trim();
                var selectedField = fieldSelect.value;
                var rows = document.querySelectorAll('table tbody tr');
                
                rows.forEach(function (row) {
                    if (row.cells.length === 1 && row.cells[0].classList.contains('text-center')) return;
                    
                    var match = false;
                    if (selectedField === 'all') {
                        match = row.textContent.toLowerCase().indexOf(query) > -1;
                    } else {
                        var colIndex = parseInt(selectedField);
                        if (row.cells[colIndex]) {
                            match = row.cells[colIndex].textContent.toLowerCase().indexOf(query) > -1;
                        }
                    }
                    row.style.display = match ? '' : 'none';
                });
            }
            
            if (searchInput && fieldSelect) {
                searchInput.addEventListener('keyup', filterComplaints);
                fieldSelect.addEventListener('change', filterComplaints);
            }
        });
    </script>
}
