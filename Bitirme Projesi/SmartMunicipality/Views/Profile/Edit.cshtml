@model SmartMunicipality.Models.ProfileViewModel
@{
    ViewData["Title"] = "Profilimi Düzenle";
}

<div class="row">
    <div class="col-md-8 mx-auto mt-4">
        <div class="card" style="border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: none;">
            <div class="card-body p-5">
                <h3 class="fw-bold text-primary mb-4"><i class="mdi mdi-account-edit me-2"></i>Bilgilerimi Güncelle</h3>
                
                <form asp-action="Edit" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">Ad</label>
                            <input type="text" asp-for="Name" class="form-control" style="border-radius: 10px;" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">Soyad</label>
                            <input type="text" asp-for="Surname" class="form-control" style="border-radius: 10px;" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">E-Posta Adresi</label>
                            <input type="email" asp-for="Email" class="form-control" style="border-radius: 10px;" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">Telefon Numarası</label>
                            <input type="text" asp-for="Phone" class="form-control" style="border-radius: 10px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">TC Kimlik No</label>
                            <input type="text" asp-for="TcNo" class="form-control" style="border-radius: 10px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold">İlçe</label>
                            <input type="text" asp-for="District" class="form-control" placeholder="Örn: Kadıköy" style="border-radius: 10px;" />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted fw-bold">Açık Adres</label>
                            <textarea asp-for="Address" class="form-control" rows="3" style="border-radius: 10px;"></textarea>
                        </div>
                    </div>
                    
                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light" style="border-radius: 10px; padding: 0.8rem 1.5rem;">İptal</a>
                        <button type="submit" class="btn btn-primary text-white fw-bold" style="border-radius: 10px; padding: 0.8rem 1.5rem;">
                            <i class="mdi mdi-content-save me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
