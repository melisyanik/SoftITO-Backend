@model IEnumerable<SmartMunicipality.MODEL.Announcement>
@{
    ViewData["Title"] = "Tüm Duyurular ve Haberler";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4">Gündem ve Duyurular</h2>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100" style="border-radius: 15px; border: none; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
                    <div class="card-body">
                        <span class="badge" style="background: var(--color-secondary); color: var(--color-dark); margin-bottom: 0.5rem;">
                            @item.PublishDate.ToString("dd.MM.yyyy HH:mm")
                        </span>
                        <h5 class="card-title fw-bold text-dark mt-2">@item.Title</h5>
                        <p class="card-text text-muted" style="line-height: 1.6;">@item.Content</p>
                    </div>
                </div>
            </div>
        }
        
        @if(!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-light text-center p-5" style="border-radius: 20px;">
                    <i class="mdi mdi-information-outline fs-1 text-muted"></i>
                    <h5 class="mt-3">Şu an için aktif bir duyuru bulunmamaktadır.</h5>
                </div>
            </div>
        }
    </div>
</div>
