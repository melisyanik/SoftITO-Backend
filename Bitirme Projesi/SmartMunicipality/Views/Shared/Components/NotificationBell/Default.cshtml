@model IEnumerable<SmartMunicipality.MODEL.Notification>

<li class="nav-item dropdown">
    <a class="nav-link count-indicator dropdown-toggle" id="notificationDropdown" href="#" data-bs-toggle="dropdown">
        <i class="mdi mdi-bell-outline" style="color: black;"></i>
        @if (Model != null && Model.Any())
        {
            <span class="count-symbol bg-danger" style="position: absolute; top: 12px; right: 12px; width: 8px; height: 8px; border-radius: 50%;"></span>
        }
    </a>
    <div class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list shadow" aria-labelledby="notificationDropdown" style="border-radius: 15px; border: none; min-width: 300px; padding: 0;">
        <div style="background: var(--color-dark); color: white; border-radius: 15px 15px 0 0; padding: 1rem;">
            <h6 class="mb-0 fw-bold">Bildirimler</h6>
        </div>
        
        <div style="max-height: 300px; overflow-y: auto;">
            @if (Model != null && Model.Any())
            {
                foreach (var notif in Model)
                {
                    <a class="dropdown-item preview-item py-3 border-bottom" style="white-space: normal;">
                        <div class="preview-thumbnail me-3">
                            <div class="preview-icon rounded-circle d-flex align-items-center justify-content-center text-white" 
                                 style="width: 40px; height: 40px; background: @(notif.NotificationType == "Bill" ? "var(--color-secondary)" : "var(--color-primary)")">
                                <i class="mdi @(notif.NotificationType == "Bill" ? "mdi-receipt" : "mdi-check") fs-4"></i>
                            </div>
                        </div>
                        <div class="preview-item-content">
                            <h6 class="preview-subject fw-bold mb-1 text-dark" style="font-size: 0.9rem;">@notif.Title</h6>
                            <p class="text-muted mb-0" style="font-size: 0.8rem; line-height: 1.4;"> @notif.Message </p>
                            <small class="text-secondary" style="font-size: 0.7rem;">@notif.CreatedDate.ToString("dd MMM HH:mm")</small>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="p-4 text-center">
                    <i class="mdi mdi-bell-sleep-outline fs-1 text-muted"></i>
                    <p class="mb-0 text-muted mt-2">Yeni bildiriminiz bulunmuyor.</p>
                </div>
            }
        </div>
        
        <a asp-controller="Notifications" asp-action="Index" style="text-decoration: none; display: block; background: var(--color-bg); border-radius: 0 0 15px 15px; padding: 0.8rem; text-align: center; cursor: pointer;">
            <span class="text-primary fw-bold" style="font-size: 0.85rem;">Tüm bildirimleri gör</span>
        </a>
    </div>
</li>
