@model IEnumerable<System.Text.Json.JsonElement>
@{
    ViewData["Title"] = "Yoğunluk Haritası";
}

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var map = L.map('adminHeatmap').setView([41.0082, 28.9784], 11);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap &copy; CARTO',
                maxZoom: 19
            }).addTo(map);

            // Fetch the points serialized from model
            var rawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
            var heatData = [];

            rawData.forEach(function (p) {
                // If it has lat/lng, map it
                var lat = p.latitude ?? p.Latitude;
                var lng = p.longitude ?? p.Longitude;
                if (lat && lng) {
                    // Adding intensity 0.8 default
                    heatData.push([lat, lng, 0.8]);

                    // Add a tiny marker too for debugging or pinpointing
                    L.circle([lat, lng], {
                        color: 'red',
                        fillColor: '#f03',
                        fillOpacity: 0.3,
                        radius: 100
                    }).addTo(map).bindPopup("<b>" + (p.title ?? p.Title) + "</b><br>İlçe: " + (p.address ?? p.Address) + "<br>Durum: " + (p.statusName ?? p.StatusName));
                }
            });

            if (heatData.length > 0 && typeof L.heatLayer !== 'undefined') {
                L.heatLayer(heatData, {
                    radius: 40,
                    blur: 20,
                    maxZoom: 13,
                    gradient: {0.4: 'blue', 0.6: 'cyan', 0.7: 'lime', 0.8: 'yellow', 1.0: 'red'}
                }).addTo(map);
            }
        });
    </script>
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-map-marker-radius"></i>
        </span> Şikayet Yoğunluk Haritası (Admin)
    </h3>
</div>

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card" style="border-radius: 20px; border: none; box-shadow: 0 10px 20px rgba(0,0,0,0.03); padding: 1rem;">
            <div class="card-body">
                <h4 class="card-title">İstanbul Şikayet HeatMap Analizi</h4>
                <p class="text-muted">Aşağıdaki haritada şikayetlerin koordinat bazlı yoğunluk bölgeleri gösterilmektedir. Kırmızı bölgeler en yoğun şikayet noktalarını temsil eder.</p>
                <div id="adminHeatmap" style="height: 550px; border-radius: 16px;"></div>
            </div>
        </div>
    </div>
</div>
