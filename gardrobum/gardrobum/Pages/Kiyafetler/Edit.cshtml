@page
@model gardrobum.Pages.Kiyafetler.EditModel

<h2>✏️ Kıyafet Düzenle</h2>

<div class="card-pro">

    <form method="post">

        <input type="hidden" name="ID" value="@Model.k.ID" />

        <input class="form-control mb-2" name="UrunAdi" value="@Model.k.UrunAdi" />
        <select name="Tur" class="form-select mb-3">
            <option value="">-- Kıyafet Türü Seç --</option>
            <option value="Üst Giyim">Üst Giyim</option>
            <option value="Alt Giyim">Alt Giyim</option>

        </select>
        <input class="form-control mb-2" name="Renk" value="@Model.k.Renk" />
        <input class="form-control mb-2" name="Beden" value="@Model.k.Beden" />
        <input class="form-control mb-2" name="Marka" value="@Model.k.Marka" />
        <input class="form-control mb-2" name="EklenmeTarihi" value="@Model.k.EklenmeTarihi" />

        <button class="btn btn-pro">Güncelle</button>

    </form>

</div>
