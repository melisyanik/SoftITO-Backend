@using SmartLifeMvc.ViewModels
@model List<GoalWithProgressVM>
@{ ViewData["Title"] = "Goals"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="page-title">My Goals</h3>
        <p class="page-sub">@Model.Count goal@(Model.Count != 1 ? "s" : "") total</p>
    </div>
    <a asp-action="Create" class="btn-action">+ New Goal</a>
</div>

<form method="get" class="search-row mb-4">
    <input type="text" name="searchText" class="s-input" placeholder="Search goals..." value="@Context.Request.Query["searchText"]" />
    <select name="status" class="s-select" onchange="this.form.submit()">
        <option value="">All statuses</option>
        <option value="Active"    selected="@(Context.Request.Query["status"]=="Active")">Active</option>
        <option value="InProgress" selected="@(Context.Request.Query["status"]=="InProgress")">In Progress</option>
        <option value="Done"      selected="@(Context.Request.Query["status"]=="Done")">Completed</option>
    </select>
    <button class="btn-search">Search</button>
</form>

@if (!Model.Any())
{
    <div class="empty-box">
        <div class="empty-icon">🎯</div>
        <p>No goals yet. Set your first one!</p>
        <a asp-action="Create" class="btn-action">+ New Goal</a>
    </div>
}
else
{
    <div class="grid-3">
        @foreach (var item in Model)
        {
            <div class="item-card" style="border-left: 3px solid #6C4FF6;">
                <div class="card-top">
                    <h5 class="goal-title-text">@item.Title</h5>
                    @if (item.Status == "Done")
                    {
                        <span class="r-badge badge-done">Done</span>
                    }
                    else if (item.Status == "In Progress")
                    {
                        <span class="r-badge badge-prog">In Progress</span>
                    }
                    else
                    {
                        <span class="r-badge badge-active">Active</span>
                    }
                </div>

                <p class="goal-desc">@item.Description</p>

                <div style="margin-bottom:10px;">
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar" style="width:@item.Progress%"></div>
                    </div>
                    <small style="font-size:11px; color:#9CA3AF; margin-top:3px; display:block;">@item.Progress% completed</small>
                </div>

                <small style="font-size:11px; color:#9CA3AF; display:block; margin-bottom:14px;">
                    Started @item.StartDate.ToShortDateString()
                </small>

                <div class="card-actions">
                    <a asp-action="Details" asp-route-id="@item.GoalId" class="btn-edit">Open</a>
                    <a asp-action="Edit" asp-route-id="@item.GoalId" class="btn-edit">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.GoalId" class="btn-del" onclick="return confirm('Delete this goal?')">Delete</a>
                </div>
            </div>
        }
    </div>
}
