<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartLife</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            background: #0F0E1A;
        }

        /* LEFT PANEL */
        .auth-left {
            flex: 1;
            background: linear-gradient(145deg, #1A1530 0%, #0F0E1A 60%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 52px;
            position: relative;
            overflow: hidden;
        }

        .auth-left::before {
            content: '';
            position: absolute;
            top: -120px; left: -120px;
            width: 480px; height: 480px;
            background: radial-gradient(circle, rgba(108,79,246,0.25) 0%, transparent 70%);
            pointer-events: none;
        }
        .auth-left::after {
            content: '';
            position: absolute;
            bottom: -80px; right: -80px;
            width: 320px; height: 320px;
            background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
            pointer-events: none;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 52px;
        }
        .brand-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #6C4FF6, #818CF8);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px;
        }
        .brand-name {
            font-size: 18px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.3px;
        }

        .auth-headline {
            font-size: 38px;
            font-weight: 700;
            color: white;
            line-height: 1.2;
            letter-spacing: -1px;
            margin-bottom: 16px;
        }
        .auth-headline span { color: #818CF8; }

        .auth-tagline {
            font-size: 15px;
            color: rgba(255,255,255,0.45);
            line-height: 1.7;
            max-width: 340px;
        }

        .auth-features {
            margin-top: 48px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .auth-feature {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13.5px;
            color: rgba(255,255,255,0.55);
        }
        .feat-dot {
            width: 6px; height: 6px;
            background: #6C4FF6;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* RIGHT PANEL */
        .auth-right {
            width: 480px;
            flex-shrink: 0;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 52px 48px;
        }

        .auth-form-wrap { width: 100%; }

        .auth-form-title {
            font-size: 24px;
            font-weight: 700;
            color: #1C1B2E;
            margin-bottom: 6px;
        }
        .auth-form-sub {
            font-size: 13.5px;
            color: #9CA3AF;
            margin-bottom: 32px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 5px;
        }

        .auth-input {
            width: 100%;
            border: 1.5px solid #E5E7EB;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: 14px;
            font-family: inherit;
            color: #1C1B2E;
            transition: 0.15s;
            outline: none;
            display: block;
        }
        .auth-input:focus {
            border-color: #6C4FF6;
            box-shadow: 0 0 0 3px rgba(108,79,246,0.12);
        }

        .auth-field { margin-bottom: 18px; }
        .error-text { font-size: 12px; color: #EF4444; margin-top: 4px; display: block; }
        .auth-error {
            background: #FEF2F2; border: 1px solid #FECACA;
            border-radius: 10px; padding: 10px 14px;
            font-size: 13px; color: #B91C1C;
            margin-bottom: 20px;
        }

        .auth-btn {
            width: 100%;
            background: linear-gradient(135deg, #6C4FF6, #818CF8);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-size: 14.5px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: opacity 0.15s, transform 0.1s;
            margin-top: 4px;
        }
        .auth-btn:hover { opacity: 0.92; transform: translateY(-1px); }

        .auth-switch {
            text-align: center;
            margin-top: 22px;
            font-size: 13px;
            color: #9CA3AF;
        }
        .auth-switch a { color: #6C4FF6; text-decoration: none; font-weight: 500; }
        .auth-switch a:hover { text-decoration: underline; }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 22px;
        }
        .remember-row input { accent-color: #6C4FF6; width: 15px; height: 15px; }
        .remember-row label { margin: 0; font-size: 13px; color: #6B7280; }

        @@media (max-width: 768px) {
            .auth-left { display: none; }
            .auth-right { width: 100%; padding: 40px 28px; }
        }
    </style>
</head>
<body>

<div class="auth-left">
    <div class="brand-mark">
        <div class="brand-icon">✦</div>
        <span class="brand-name">SmartLife</span>
    </div>

    <h1 class="auth-headline">
        Your goals,<br>
        <span>organized.</span>
    </h1>
    <p class="auth-tagline">
        Track your progress, manage tasks, collect insights — all in one place built for you.
    </p>

    <div class="auth-features">
        <div class="auth-feature"><span class="feat-dot"></span>Personal goal tracking with progress history</div>
        <div class="auth-feature"><span class="feat-dot"></span>Task management with priority filters</div>
        <div class="auth-feature"><span class="feat-dot"></span>Notes and inspirational quotes</div>
        <div class="auth-feature"><span class="feat-dot"></span>Reports exportable to PDF and Excel</div>
    </div>
</div>

<div class="auth-right">
    <div class="auth-form-wrap">
        @RenderBody()
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
