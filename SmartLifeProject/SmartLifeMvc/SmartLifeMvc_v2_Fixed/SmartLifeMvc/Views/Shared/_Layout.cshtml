<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartLife</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand:      #6C4FF6;
            --brand-dark: #5A3DE0;
            --brand-soft: #EDE9FE;
            --surface:    #FFFFFF;
            --bg:         #F5F4FF;
            --border:     #E8E5FF;
            --text:       #1C1B2E;
            --muted:      #6B7280;
            --success:    #16A34A;
            --warning:    #B45309;
            --danger:     #DC2626;
            --badge-active-bg:  #DBEAFE;
            --badge-active-fg:  #1D4ED8;
            --badge-prog-bg:    #FEF3C7;
            --badge-prog-fg:    #92400E;
            --badge-done-bg:    #DCFCE7;
            --badge-done-fg:    #15803D;
            --radius:     14px;
            --shadow:     0 4px 20px rgba(108,79,246,0.08);
            --shadow-hover: 0 8px 30px rgba(108,79,246,0.16);
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            min-height: 100vh;
        }

        /* ── NAVBAR ── */
        .sl-nav {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 28px;
            display: flex;
            align-items: center;
            height: 58px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 8px rgba(108,79,246,0.06);
        }

        .sl-brand {
            font-weight: 700;
            font-size: 17px;
            color: var(--brand);
            text-decoration: none;
            letter-spacing: -0.3px;
            margin-right: 32px;
            flex-shrink: 0;
        }

        .sl-nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            flex: 1;
        }

        .sl-nav-link {
            font-size: 13.5px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            padding: 6px 12px;
            border-radius: 8px;
            transition: background 0.15s, color 0.15s;
        }

        .sl-nav-link:hover,
        .sl-nav-link.active {
            background: var(--brand-soft);
            color: var(--brand);
        }

        .sl-nav-right {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }

        .sl-logout {
            font-size: 13px;
            color: var(--muted);
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 8px;
            border: 1px solid var(--border);
            transition: 0.15s;
        }

        .sl-logout:hover { border-color: var(--brand); color: var(--brand); }

        /* ── MAIN ── */
        .sl-main { padding: 32px 28px; max-width: 1200px; margin: 0 auto; }

        /* ── PAGE HEADER ── */
        .page-title { font-size: 22px; font-weight: 700; color: var(--text); margin: 0; }
        .page-sub { font-size: 13px; color: var(--muted); margin: 2px 0 0; }

        /* ── CARDS ── */
        .card-soft {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            padding: 22px;
            transition: box-shadow 0.2s, transform 0.2s;
        }
        .card-soft:hover {
            box-shadow: var(--shadow-hover);
            transform: translateY(-2px);
        }

        /* ── ITEM CARDS (Notes / Quotes) ── */
        .grid-3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
        .grid-2 { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; }

        .item-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px;
            box-shadow: var(--shadow);
            transition: 0.2s;
        }
        .item-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-2px); }

        .note-card { border-left: 3px solid var(--brand); }

        .quote-card {
            background: linear-gradient(135deg, #FAF9FF, #F0EEFF);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 22px;
        }

        .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
        .card-title { font-size: 15px; font-weight: 600; color: var(--text); margin: 0; }
        .card-date { font-size: 11px; color: var(--muted); white-space: nowrap; }
        .card-body { font-size: 13.5px; color: var(--muted); margin: 0 0 14px; line-height: 1.6; }

        .quote-mark { font-size: 48px; color: var(--brand); line-height: 1; margin-bottom: 4px; font-family: Georgia, serif; opacity: 0.3; }
        .quote-text { font-size: 15px; color: var(--text); font-style: italic; line-height: 1.6; margin-bottom: 14px; }
        .quote-footer { display: flex; justify-content: space-between; align-items: center; }
        .quote-author { font-size: 12px; font-weight: 600; color: var(--brand); }

        .card-actions { display: flex; gap: 8px; }

        /* ── TASK LIST ── */
        .task-list { display: flex; flex-direction: column; gap: 10px; }

        .task-row {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: 0.2s;
        }
        .task-row:hover { box-shadow: var(--shadow); }
        .task-done { opacity: 0.65; background: #FAFAFA; }

        .task-check {
            width: 22px; height: 22px;
            border: 2px solid var(--border);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none;
            font-size: 12px;
            color: transparent;
            flex-shrink: 0;
            transition: 0.15s;
        }
        .task-check.checked { background: var(--brand); border-color: var(--brand); color: white; }
        .task-check:hover { border-color: var(--brand); }

        .task-info { flex: 1; min-width: 0; }
        .task-title { font-size: 14px; font-weight: 500; color: var(--text); display: block; }
        .task-date { font-size: 11px; color: var(--muted); }
        .striked { text-decoration: line-through; color: var(--muted) !important; }
        .task-btns { display: flex; gap: 6px; }

        /* ── BUTTONS ── */
        .btn-action {
            display: inline-flex; align-items: center; gap: 4px;
            background: var(--brand);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 9px 18px;
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            line-height: 1;
        }
        .btn-action:hover { background: var(--brand-dark); color: white; transform: translateY(-1px); }

        .btn-edit {
            font-size: 12.5px; font-weight: 500;
            color: var(--brand);
            text-decoration: none;
            padding: 5px 12px;
            border-radius: 8px;
            border: 1px solid var(--brand-soft);
            background: var(--brand-soft);
            transition: 0.15s;
        }
        .btn-edit:hover { background: var(--brand); color: white; }

        .btn-del {
            font-size: 12.5px; font-weight: 500;
            color: var(--danger);
            text-decoration: none;
            padding: 5px 12px;
            border-radius: 8px;
            border: 1px solid #FEE2E2;
            background: #FEF2F2;
            transition: 0.15s;
        }
        .btn-del:hover { background: var(--danger); color: white; }

        .btn-cancel {
            display: inline-flex; align-items: center;
            color: var(--muted);
            text-decoration: none;
            padding: 9px 18px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-size: 13.5px;
            font-weight: 500;
            background: white;
            transition: 0.15s;
        }
        .btn-cancel:hover { border-color: var(--brand); color: var(--brand); }

        /* ── SEARCH ── */
        .search-row { display: flex; gap: 10px; align-items: center; }

        .s-input, .s-select {
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 9px 14px;
            font-size: 13.5px;
            font-family: inherit;
            color: var(--text);
            background: white;
            transition: 0.15s;
            outline: none;
        }
        .s-input { flex: 1; }
        .s-input:focus, .s-select:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(108,79,246,0.1); }

        .btn-search {
            background: var(--brand);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 9px 18px;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.15s;
        }
        .btn-search:hover { background: var(--brand-dark); }

        .btn-clear {
            font-size: 13px;
            color: var(--muted);
            text-decoration: none;
            padding: 9px 12px;
            border-radius: 8px;
            border: 1px solid var(--border);
            transition: 0.15s;
        }
        .btn-clear:hover { color: var(--danger); border-color: var(--danger); }

        /* ── FORM STYLES ── */
        .form-page { max-width: 580px; }
        .back-link { font-size: 13px; color: var(--muted); text-decoration: none; display: inline-block; margin-bottom: 18px; }
        .back-link:hover { color: var(--brand); }

        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 32px;
            box-shadow: var(--shadow);
        }
        .form-title { font-size: 20px; font-weight: 700; color: var(--text); margin: 0 0 24px; }

        .field { margin-bottom: 18px; }
        .field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 6px;
        }

        .f-input {
            width: 100%;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 14px;
            font-family: inherit;
            color: var(--text);
            background: white;
            transition: 0.15s;
            outline: none;
            display: block;
        }
        .f-input:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(108,79,246,0.1); }

        /* FIX: Hatalı validation kırmızı border'ı override et */
        .f-input.input-validation-error { border-color: #EF4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.1) !important; }
        .field-validation-error { font-size: 12px; color: #EF4444; margin-top: 4px; display: block; }

        .f-textarea { min-height: 110px; resize: vertical; }
        .field-check { display: flex; align-items: center; gap: 10px; }
        .field-check input[type=checkbox] { width: 18px; height: 18px; accent-color: var(--brand); flex-shrink: 0; }

        .form-btns { display: flex; gap: 10px; margin-top: 24px; }

        .f-err { font-size: 12px; color: #EF4444; margin-top: 4px; display: block; }

        /* ── BADGES ── */
        .r-badge, .priority-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 600;
        }

        /* Goal status badges — no overlap */
        .badge-active { background: var(--badge-active-bg) !important; color: var(--badge-active-fg) !important; }
        .badge-prog   { background: var(--badge-prog-bg) !important;   color: var(--badge-prog-fg) !important; }
        .badge-done   { background: var(--badge-done-bg) !important;   color: var(--badge-done-fg) !important; }

        /* Task priority */
        .priority-high   { background: #FEE2E2; color: #B91C1C; }
        .priority-medium { background: #FEF3C7; color: #92400E; }
        .priority-low    { background: #DCFCE7; color: #15803D; }

        /* ── EMPTY STATE ── */
        .empty-box {
            text-align: center; padding: 60px 20px;
            color: var(--muted); background: var(--surface);
            border: 1px dashed var(--border); border-radius: var(--radius);
        }
        .empty-icon { font-size: 40px; margin-bottom: 12px; }
        .empty-box p { font-size: 14px; margin: 0 0 12px; }

        /* ── PROGRESS ── */
        .progress { background: var(--border) !important; border-radius: 10px; }
        .progress-bar {
            background: linear-gradient(90deg, var(--brand), #818CF8) !important;
            border-radius: 10px;
            transition: width 0.5s ease;
        }
        .mini-progress { height: 5px; background: var(--border); border-radius: 4px; width: 80px; display: inline-block; vertical-align: middle; }
        .mini-bar { height: 5px; background: var(--brand); border-radius: 4px; }

        /* ── REPORT ── */
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 20px; text-align: center;
            box-shadow: var(--shadow);
        }
        .stat-icon { font-size: 28px; margin-bottom: 8px; }
        .stat-val { font-size: 32px; font-weight: 700; color: var(--brand); }
        .stat-lbl { font-size: 13px; font-weight: 600; color: var(--text); margin-top: 2px; }
        .stat-sub { font-size: 11.5px; color: var(--muted); margin-top: 4px; }

        .report-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; margin-bottom: 18px; box-shadow: var(--shadow); }
        .section-title { font-size: 15px; font-weight: 600; color: var(--text); margin: 0 0 16px; }

        .r-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
        .r-table th { text-align: left; font-weight: 600; font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; padding: 8px 12px; border-bottom: 2px solid var(--border); }
        .r-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); }
        .r-table tr:last-child td { border-bottom: none; }
        .r-table tr:hover td { background: var(--bg); }

        .btn-export-excel { display: inline-flex; align-items: center; gap: 5px; padding: 9px 16px; border-radius: 10px; background: #DCFCE7; color: #15803D; font-size: 13px; font-weight: 600; text-decoration: none; transition: 0.15s; }
        .btn-export-excel:hover { background: #15803D; color: white; }
        .btn-export-pdf { display: inline-flex; align-items: center; gap: 5px; padding: 9px 16px; border-radius: 10px; background: #FEE2E2; color: #B91C1C; font-size: 13px; font-weight: 600; text-decoration: none; transition: 0.15s; }
        .btn-export-pdf:hover { background: #B91C1C; color: white; }

        /* ── GOAL CARDS ── */
        .goal-title-text { font-weight: 600; color: var(--text); font-size: 15px; }
        .goal-desc { font-size: 13px; color: var(--muted); margin: 6px 0 12px; }
    </style>
</head>
<body>

<nav class="sl-nav">
    <a class="sl-brand" asp-controller="Goals" asp-action="Index">✦ SmartLife</a>

    <div class="sl-nav-links">
        <a class="sl-nav-link" asp-controller="Goals" asp-action="Index">Goals</a>
        <a class="sl-nav-link" asp-controller="Tasks" asp-action="Index">Tasks</a>
        <a class="sl-nav-link" asp-controller="Notes" asp-action="Index">Notes</a>
        <a class="sl-nav-link" asp-controller="Quotes" asp-action="Index">Quotes</a>
        <a class="sl-nav-link" asp-controller="Report" asp-action="Index">Report</a>
    </div>

    <div class="sl-nav-right">
        <a class="sl-logout" asp-controller="Account" asp-action="Logout">Logout</a>
    </div>
</nav>

<div class="sl-main">
    @RenderBody()
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
