@model Goal

<div class="card-soft">

    <h3>@Model.Title</h3>

    <p class="text-muted">@Model.Description</p>

    <hr />

    <h6>Progress</h6>

    <div class="progress" style="height: 10px; border-radius: 20px;">
        <div class="progress-bar"
             style="width:@ViewBag.Progress%; background:#7C5CFF;">
        </div>
    </div>

    <small class="text-muted">
        @ViewBag.Progress% completed
    </small>

    <div class="mt-3">

        <a asp-controller="GoalProgress"
           asp-action="Create"
           asp-route-goalId="@Model.GoalId"
           class="btn btn-success">
            + Add Progress
        </a>

    </div>

</div>

<!-- 🔥 PROGRESS HISTORY EKLENDİ -->
<div class="card-soft mt-3">

    <h6>History</h6>

    @if (ViewBag.ProgressList != null)
    {
        foreach (var p in ViewBag.ProgressList)
        {
            <div class="border-bottom py-2 d-flex justify-content-between align-items-center">

                <div>
                    <b>@p.ProgressDate.ToShortDateString()</b>
                    - @p.Percentage%
                    <div class="text-muted">@p.Note</div>
                </div>

                <a asp-controller="GoalProgress"
                   asp-action="Delete"
                   asp-route-id="@p.GoalProgressId"
                   class="btn btn-sm btn-danger">
                    Delete
                </a>

            </div>
        }
    }
    else
    {
        <p class="text-muted">No progress yet</p>
    }

</div>