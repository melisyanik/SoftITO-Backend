@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using SmartLifeMvc.ViewModels.Api
@model QuoteDto
@{ ViewData["Title"] = "Add Quote"; }

<div class="form-page">
    <a asp-action="Index" class="back-link">← Quotes</a>
    <div class="form-card">
        <h4 class="form-title">Add Quote</h4>
        <form asp-action="Create" method="post">
            <div class="field">
                <label>Quote Text</label>
                <textarea asp-for="Text" class="f-input f-textarea" placeholder="The quote..."></textarea>
                <span asp-validation-for="Text" class="f-err"></span>
            </div>
            <div class="field">
                <label>Author</label>
                <input asp-for="Author" class="f-input" placeholder="Who said it?" />
            </div>
            <div class="form-btns">
                <button type="submit" class="btn-action">Save Quote</button>
                <a asp-action="Index" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>
