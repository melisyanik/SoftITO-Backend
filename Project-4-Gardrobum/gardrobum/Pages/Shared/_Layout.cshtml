<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Dolabım</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>

      
        body {
            margin: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #0a0c12;
            color: #e5e7eb;
        }

            
            body::before {
                content: "";
                position: fixed;
                width: 700px;
                height: 700px;
                top: -250px;
                left: -250px;
                background: radial-gradient(circle, rgba(99,102,241,0.15), transparent 60%);
                filter: blur(90px);
                z-index: -1;
            }

            body::after {
                content: "";
                position: fixed;
                width: 700px;
                height: 700px;
                bottom: -250px;
                right: -250px;
                background: radial-gradient(circle, rgba(236,72,153,0.12), transparent 60%);
                filter: blur(90px);
                z-index: -1;
            }

      
        .topnav {
            position: sticky;
            top: 0;
            z-index: 999;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 28px;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

     
        .brand {
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            background: linear-gradient(90deg, #8b5cf6, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        
        .nav-links {
            display: flex;
            gap: 10px;
        }

            .nav-links a {
                text-decoration: none;
                color: #cbd5e1;
                font-size: 14px;
                padding: 8px 14px;
                border-radius: 12px;
                transition: 0.25s;
                position: relative;
            }

                .nav-links a:hover {
                    background: rgba(255,255,255,0.05);
                    color: white;
                    transform: translateY(-1px);
                }

                
                .nav-links a.active {
                    background: linear-gradient(90deg, #8b5cf6, #ec4899);
                    color: white;
                    box-shadow: 0 8px 25px rgba(236,72,153,0.25);
                }

        .container-main {
            padding: 28px;
            max-width: 1200px;
            margin: auto;
        }

       
        .card-pro {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 18px;
            padding: 20px;
            transition: 0.25s;
        }

            .card-pro:hover {
                transform: translateY(-4px);
                border-color: rgba(139,92,246,0.4);
                box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            }

    
        .glow-line {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(139,92,246,0.5), transparent);
            margin: 10px 0;
        }

        .btn-pro {
            background: linear-gradient(90deg, #8b5cf6, #ec4899);
            border: none;
            color: white;
            border-radius: 12px;
            padding: 8px 14px;
            font-size: 14px;
            transition: 0.2s;
            box-shadow: 0 8px 20px rgba(236,72,153,0.15);
        }

            .btn-pro:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 30px rgba(139,92,246,0.25);
                color: white;
            }

        .btn-light-pro {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            color: #e5e7eb;
            border-radius: 12px;
            padding: 8px 14px;
        }

            .btn-light-pro:hover {
                background: rgba(255,255,255,0.12);
                color: white;
            }

        .btn-pro.btn-lg {
            font-size: 16px;
            border-radius: 14px;
            transition: 0.2s;
        }

            .btn-pro.btn-lg:hover {
                transform: scale(1.03);
            }

    </style>
</head>

<body>

    <div class="topnav">

        <div class="brand">DOLABIM • Online Gardrop</div>

        <div class="nav-links">
            <a href="/Index">Ana Sayfa</a>
            <a href="/Kiyafetler/Index">Kıyafetler</a>
            <a href="/Ayakkabilar/Index">Ayakkabılar</a>
            <a href="/Takilar/Index">Takılar</a>
        </div>

    </div>

   
    <div class="container-main">
        @RenderBody()
    </div>

</body>
</html>