@page
@model gardrobum.Pages.Ayakkabilar.IndexModel

<h2>Ayakkabılarım</h2>

<div class="card-pro p-3 mb-3">

    <form method="get">

        <select name="alan" class="form-select mb-2">
            <option value="AyakkabiAdi">Ürün</option>
            <option value="Tur">Tür</option>
            <option value="Renk">Renk</option>
            <option value="Numara">Numara</option>
            <option value="Marka">Marka</option>
        </select>

        <input type="text" name="q" class="form-control mb-2" placeholder="Ara..." />

        <button class="btn btn-pro w-100">🔍 Ara</button>

    </form>

</div>

<div class="card-pro p-3 mb-3 d-flex justify-content-between align-items-center">

    <div>
        <h5 style="color:white;">Ayakkabı Listesi</h5>
        <small style="color:#aaa;">Tüm ürünler</small>
    </div>

    <a href="/Ayakkabilar/Create" class="btn btn-pro">
        ➕ Ayakkabı Ekle
    </a>

</div>

<div class="card-pro p-2">

    <table class="table table-dark table-hover mb-0">

        <thead>
            <tr>
                <th>ID</th>
                <th>Ürün</th>
                <th>Tür</th>
                <th>Renk</th>
                <th>Numara</th>
                <th>Marka</th>
                <th>Eklenme Tarihi</th>
                <th>İşlem</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var x in Model.liste)
            {
                <tr>
                    <td>@x.ID</td>
                    <td><b>@x.AyakkabiAdi</b></td>
                    <td>@x.Tur</td>
                    <td>@x.Renk</td>
                    <td>@x.Numara</td>
                    <td>@x.Marka</td>
                    <td>@x.EklenmeTarihi</td>

                    <td class="d-flex gap-2">

                        <a class="btn btn-sm btn-light-pro px-3"
                           href="/Ayakkabilar/Edit?ID=@x.ID">
                            ✏️ Düzenle
                        </a>

                        <a class="btn btn-sm btn-light-pro px-3" 
                           href="/Ayakkabilar/Delete?ID=@x.ID"
                           onclick="return confirm('Silmek istediğine emin misin?');">
                            🗑 Sil
                        </a>

                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>