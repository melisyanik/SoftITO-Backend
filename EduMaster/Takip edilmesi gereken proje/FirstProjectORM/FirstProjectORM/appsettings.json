{
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },//---------------------------------
    "Serilog": { //Burası 30 haziran bonus konudan
      "WriteTo": [
        {
          "Name": "File",
          "Args": {
            "path": "Logs/vehicle-app-log-.txt",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 30,
            "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
          }
        }
      ]
    },//-------------------------------
    "AllowedHosts": "*",
    "ConnectionStrings": {
      "Default": "Server=(localdb)\\MSSQLLocalDB;Database=firstprojectorm;TrustServerCertificate=true;"
    }
  }
