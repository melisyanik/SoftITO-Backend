@model IEnumerable<EduMaster.Models.Course>

@{
    ViewData["Title"] = "Kurslar";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 style="color: #dc3545;">Mevcut Kurslar</h2>
    </div>
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex justify-content-end">
            <select name="categoryId" class="form-select me-2" style="max-width: 200px;" asp-items="ViewBag.CategoryList">
                <option value="">Tüm Kategoriler</option>
            </select>
            <input type="text" name="searchTitle" class="form-control me-2" placeholder="Kurs Ara..." style="max-width: 250px;" />
            <button type="submit" class="btn btn-custom">Ara</button>
        </form>
    </div>
</div>

<div class="row">
    @foreach (var course in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card card-custom h-100">
                @if (!string.IsNullOrEmpty(course.Image))
                {
                    <img src="@course.Image" class="card-img-top" alt="@course.Title" style="height: 200px; object-fit: cover; border-top-left-radius: 10px; border-top-right-radius: 10px;" />
                }
                else
                {
                    <div style="height: 200px; background-color: #e9ecef; border-top-left-radius: 10px; border-top-right-radius: 10px;" class="d-flex justify-content-center align-items-center">
                        <span class="text-muted">Resim Yok</span>
                    </div>
                }
                
                <div class="card-body">
                    <span class="badge bg-danger mb-2">@course.Category?.Name</span>
                    <h5 class="card-title fw-bold">@course.Title</h5>
                    <p class="card-text text-muted" style="height: 48px; overflow: hidden;">@course.Description</p>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-person"></i> @course.Instructor?.FullName</small>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">Kontenjan: @course.EnrolledCount / @course.Quota</small>
                        <div class="progress mt-1" style="height: 5px;">
                            @{
                                var percent = course.Quota > 0 ? (course.EnrolledCount * 100) / course.Quota : 0;
                            }
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @percent%;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-3">
                    <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-danger w-100">Detayları Gör</a>
                </div>
            </div>
        </div>
    }
    
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-secondary text-center">
                Aradığınız kriterlere uygun kurs bulunamadı.
            </div>
        </div>
    }
</div>
