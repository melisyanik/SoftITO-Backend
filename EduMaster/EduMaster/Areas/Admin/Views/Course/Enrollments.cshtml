@model IEnumerable<EduMaster.Models.Enrollment>

@{
    ViewData["Title"] = "Kayıtlı Öğrenciler";
    var courseTitle = ViewBag.CourseTitle;
    var courseId = ViewBag.CourseId;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 style="color: #dc3545;">@courseTitle - Kayıtlı Öğrenciler</h2>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Kurslara Dön</a>
    </div>
</div>

<div class="card card-custom p-4">
    <table class="table table-hover table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Fotoğraf</th>
                <th>Ad Soyad</th>
                <th>E-Posta</th>
                <th>Kayıt Tarihi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (item.User != null && !string.IsNullOrEmpty(item.User.Image))
                        {
                            <img src="@item.User.Image" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;" />
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-person"></i>
                            </div>
                        }
                    </td>
                    <td class="fw-bold">@(item.User?.FullName ?? "Bilinmeyen Kullanıcı")</td>
                    <td>@(item.User?.Email ?? "Bilinmiyor")</td>
                    <td>@item.EnrollDate.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">Bu kursa henüz kayıt olan öğrenci bulunmamaktadır.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
