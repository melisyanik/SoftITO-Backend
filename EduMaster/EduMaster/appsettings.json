{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "Serilog": {
      "WriteTo": [
        {
          "Name": "File",
          "Args": {
            "path": "Logs/edumaster-log-.txt",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 30,
            "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
          }
        }
      ]
    },
    "AllowedHosts":  "*",
    "ConnectionStrings":  {
                              "DefaultConnection":  "Server=(localdb)\\MSSQLLocalDB;Database=EduMasterDb;Trusted_Connection=True;TrustServerCertificate=True"
                          },
    "EPPlus":  {
                   "ExcelPackage":  {
                                        "LicenseContext":  "NonCommercial"
                                    }
               }
}
