@model IEnumerable<PetCareTrackerMVC.Models.PetDto>
@{ ViewData["Title"] = "Hastalar"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-heart-pulse text-danger"></i> Kayıtlı Hastalar</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle"></i> Yeni Hasta Ekle</a>
        <a asp-action="ExportPdf" class="btn btn-outline-danger shadow-sm ms-2"><i class="bi bi-file-pdf"></i> PDF İndir</a>
        <a asp-action="ExportExcel" class="btn btn-outline-success shadow-sm ms-2"><i class="bi bi-file-excel"></i> Excel İndir</a>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Adı</th><th>Türü</th><th>Irkı</th><th>Cinsiyet</th><th>Doğum Tarihi</th><th>Ağırlık</th><th class="text-end pe-4">İşlemler</th></tr></thead>
            <tbody>
                @foreach(var p in Model) {
                    <tr>
                        <td class="align-middle fw-bold ps-3">@p.PetName</td><td class="align-middle">@p.Species</td><td class="align-middle">@p.Breed</td><td class="align-middle">@p.Gender</td>
                        <td class="align-middle">@p.BirthDate?.ToString("dd/MM/yyyy")</td><td class="align-middle">@p.Weight kg</td>
                        <td class="text-end align-middle pe-3">
                            <a asp-action="Edit" asp-route-id="@p.PetId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" asp-route-id="@p.PetId" method="post" class="d-inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
