@model PetCareTrackerMVC.Models.PetDto
@{ ViewData["Title"] = "Hasta Düzenle"; }
<div class="card shadow-sm border-0 mx-auto mt-4" style="max-width: 600px;">
    <div class="card-body p-5">
        <h3 class="mb-4 text-center">Hasta Düzenle</h3>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="PetId" />
            <div class="mb-3"><label class="form-label fw-semibold">Adı</label><input asp-for="PetName" class="form-control bg-light" required/></div>
            <div class="mb-3"><label class="form-label fw-semibold">Türü</label><input asp-for="Species" class="form-control bg-light" required/></div>
            <div class="mb-3"><label class="form-label fw-semibold">Irkı</label><input asp-for="Breed" class="form-control bg-light" /></div>
            <div class="mb-3"><label class="form-label fw-semibold">Cinsiyet</label>
                <select asp-for="Gender" class="form-select bg-light"><option value="Erkek">Erkek</option><option value="Dişi">Dişi</option></select>
            </div>
            <div class="mb-3"><label class="form-label fw-semibold">Doğum Tarihi</label><input asp-for="BirthDate" type="date" class="form-control bg-light" /></div>
            <div class="mb-3"><label class="form-label fw-semibold">Ağırlık (kg)</label><input asp-for="Weight" type="number" step="0.1" class="form-control bg-light" /></div>
            <button type="submit" class="btn btn-primary btn-lg w-100 mt-3 shadow-sm">Güncelle</button>
        </form>
    </div>
</div>
