@model IEnumerable<PetCareTrackerMVC.Models.VaccinationDto>
@{ ViewData["Title"] = "Aşı Takibi"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-syringe text-info"></i> Aşı Takibi</h2>
    @if(!User.IsInRole("Admin")) {
        <a asp-action="Create" class="btn btn-info text-white shadow-sm"><i class="bi bi-plus-circle"></i> Aşı Ekle</a>
    }
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Hasta Adı</th><th>Aşı Adı</th><th>Aşı Tarihi</th><th>Tekrar Tarihi</th><th class="text-end pe-4">İşlemler</th></tr></thead>
            <tbody>
                @if(Model != null) {
                    foreach(var v in Model) {
                        <tr>
                            <td class="align-middle fw-bold ps-3">@v.PetName</td><td class="align-middle">@v.VaccineName</td>
                            <td class="align-middle">@v.VaccinationDate.ToString("dd/MM/yyyy")</td>
                            <td class="align-middle">@(v.NextDueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-end align-middle pe-3">
                                <form asp-action="Delete" asp-route-id="@v.VaccinationId" method="post" class="d-inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
