@model PetCareTrackerMVC.Models.VaccinationDto
@{ ViewData["Title"] = "Aşı Ekle"; var pets = ViewBag.Pets as IEnumerable<PetCareTrackerMVC.Models.PetDto>; }
<div class="card shadow-sm border-0 mx-auto mt-4" style="max-width: 600px;">
    <div class="card-body p-5">
        <h3 class="mb-4 text-center">Aşı Kaydı</h3>
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Hasta</label>
                @if(User.IsInRole("Admin")) {
                    <select asp-for="PetId" class="form-select bg-light" required>
                        <option value="">-- Hasta Seçin --</option>
                        @if(pets != null && pets.Any()) { 
                            foreach(var p in pets) { 
                                <option value="@p.PetId">@p.PetName</option> 
                            } 
                        }
                    </select>
                } else {
                    <input asp-for="PetName" class="form-control bg-light" placeholder="Hastanızın (Pet) adını yazın" required />
                }
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Aşı Seçin (Aşı Adı)</label>
                <select asp-for="VaccineName" class="form-select bg-light" required>
                    <option value="">-- Aşı Seçin --</option>
                    <option value="Kuduz">Kuduz</option>
                    <option value="Karma">Karma</option>
                    <option value="Lösemi">Lösemi</option>
                    <option value="FIV">FIV</option>
                    <option value="Parazit">Parazit (İç/Dış)</option>
                    <option value="Lyme">Lyme</option>
                    <option value="Bordetella">Bordetella</option>
                    <option value="Diğer">Diğer</option>
                </select>
            </div>
            <div class="mb-3"><label class="form-label fw-semibold">Yapılış Tarihi</label><input asp-for="VaccinationDate" type="date" class="form-control bg-light" required/></div>
            <div class="mb-3"><label class="form-label fw-semibold">Sonraki Tekrar (Opsiyonel)</label><input asp-for="NextDueDate" type="date" class="form-control bg-light" /></div>
            <div class="mb-3"><label class="form-label fw-semibold">Notlar</label><textarea asp-for="Notes" class="form-control bg-light" rows="2"></textarea></div>
            <button type="submit" class="btn btn-info text-white btn-lg w-100 mt-3 shadow-sm">Kaydet</button>
        </form>
    </div>
</div>
