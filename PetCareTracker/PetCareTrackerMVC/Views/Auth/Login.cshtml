@model PetCareTrackerMVC.Models.LoginDto
@{ ViewData["Title"] = "Giriþ Yap"; }
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card p-4">
            <h2 class="text-center mb-4">Sisteme Giriþ</h2>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">E-Posta Adresi</label>
                    <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Þifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2">Giriþ Yap</button>
                <div asp-validation-summary="All" class="text-danger mt-3"></div>
            </form>
        </div>
    </div>
</div>
