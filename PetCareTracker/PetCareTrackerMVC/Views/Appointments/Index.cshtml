@model IEnumerable<PetCareTrackerMVC.Models.AppointmentDto>
@{ ViewData["Title"] = "Randevular"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check text-primary"></i> Randevular</h2>
    @if(!User.IsInRole("Admin")) {
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle"></i> Randevu Al</a>
    }
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Hasta Adı</th><th>Tarih</th><th>Veteriner</th><th>Durum</th><th class="text-end pe-4">İşlemler</th></tr></thead>
            <tbody>
                @foreach(var a in Model) {
                    <tr>
                        <td class="align-middle fw-bold ps-3">@a.PetName</td>
                        <td class="align-middle">@a.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="align-middle">@a.Veterinarian</td>
                        <td class="align-middle">
                            @if(a.Status == "Bekliyor") { <span class="badge bg-warning text-dark">Bekliyor</span> }
                            else { <span class="badge bg-success">Tamamlandı</span> }
                        </td>
                        <td class="text-end align-middle pe-3">
                            @if(User.IsInRole("Admin")) {
                                <form asp-action="UpdateStatus" asp-route-id="@a.AppointmentId" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="@(a.Status == "Bekliyor" ? "Tamamlandı" : "Bekliyor")" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Durumu Değiştir"><i class="bi bi-arrow-repeat"></i></button>
                                </form>
                            }
                            <form asp-action="Delete" asp-route-id="@a.AppointmentId" method="post" class="d-inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
