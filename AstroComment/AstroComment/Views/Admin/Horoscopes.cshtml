@model IEnumerable<AstroComment.ViewModels.HoroscopeVM>

@{
    ViewData["Title"] = "Burç Yorumları Yönetimi";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="text-white">Burç Yorumları</h2>
    </div>
    <div class="col-md-4 text-end">
        <a href="/Admin/CreateHoroscope" class="btn btn-primary">Yeni Yorum Ekle</a>
    </div>
</div>

<div class="card card-glass p-4">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Burç</th>
                    <th>Yorum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.HoroscopeDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.ZodiacName</td>
                            <td>
                                @if (item.Content.Length > 50)
                                {
                                    @($"{item.Content.Substring(0, 50)}...")
                                }
                                else
                                {
                                    @item.Content
                                }
                            </td>
                            <td>
                                <a href="/Admin/EditHoroscope/@item.HoroscopeId" class="btn btn-sm btn-warning">Düzenle</a>
                                <a href="/Admin/DeleteHoroscope/@item.HoroscopeId" class="btn btn-sm btn-danger" onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?');">Sil</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-secondary">Henüz kayıtlı bir burç yorumu bulunmuyor.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
