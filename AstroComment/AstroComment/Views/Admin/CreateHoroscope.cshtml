@model AstroComment.ViewModels.HoroscopeVM

@{
    ViewData["Title"] = "Yeni Burç Yorumu Ekle";
    var zodiacs = ViewBag.Zodiacs as IEnumerable<AstroComment.Models.ZodiacModel>;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-glass p-4">
            <h3 class="text-white mb-4">Yeni Burç Yorumu Ekle</h3>

            <form action="/Admin/CreateHoroscope" method="post">
                <div class="mb-3">
                    <label class="form-label text-light">Burç</label>
                    <select class="form-select bg-dark text-white border-secondary" name="ZodiacId" required>
                        <option value="">Seçiniz...</option>
                        @if (zodiacs != null)
                        {
                            foreach (var z in zodiacs)
                            {
                                <option value="@z.ZodiacId">@z.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label text-light">Tarih</label>
                    <input type="date" class="form-control bg-dark text-white border-secondary" name="HoroscopeDate" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-light">Yorum İçeriği</label>
                    <textarea class="form-control bg-dark text-white border-secondary" name="Content" rows="5" required></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Admin/Horoscopes" class="btn btn-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
