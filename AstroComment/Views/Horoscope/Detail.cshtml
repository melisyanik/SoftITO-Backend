@model AstroComment.ViewModels.HoroscopeVM
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = $"{Model.ZodiacName} Burç Yorumu";
    var comments = ViewBag.Comments as IEnumerable<AstroComment.ViewModels.CommentVM>;
    var emojis = new Dictionary<string, string> {
        { "Koç", "♈" }, { "Boğa", "♉" }, { "İkizler", "♊" }, { "Yengeç", "♋" },
        { "Aslan", "♌" }, { "Başak", "♍" }, { "Terazi", "♎" }, { "Akrep", "♏" },
        { "Yay", "♐" }, { "Oğlak", "♑" }, { "Kova", "♒" }, { "Balık", "♓" }
    };
    var emoji = emojis.ContainsKey(Model.ZodiacName) ? emojis[Model.ZodiacName] : "🔮";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        
        <a href="/" class="btn btn-outline-light btn-sm px-3 rounded-pill mb-4">
            ⬅️ Burçlar Listesine Dön
        </a>

        
        <div class="card card-glass p-5 mb-5 text-center position-relative overflow-hidden">
            <div class="position-absolute start-0 top-0 w-100 h-100 opacity-5" style="background: radial-gradient(circle, rgba(124, 58, 237, 0.4) 0%, transparent 70%);"></div>
            
            <div class="display-1 floating-icon mb-3 text-glow">
                @emoji
            </div>
            
            <h1 class="display-4 fw-bold text-gradient mb-2 text-wrap-fix">@Model.ZodiacName Burcu</h1>
            <h5 class="text-secondary mb-4">📅 Günlük Burç Yorumu - @Model.HoroscopeDate.ToString("dd MMMM yyyy")</h5>
            
            <div class="p-4 rounded-4 bg-white bg-opacity-5 border border-white-50 border-opacity-10 text-start shadow-sm">
                <p class="fs-5 text-white lh-lg mb-0 text-wrap-fix">
                    @Model.Content
                </p>
            </div>
        </div>

        
        <div class="card card-glass p-4 mb-5">
            <h4 class="fw-bold mb-3 text-white">💬 Düşüncelerini Paylaş</h4>
            
            @if (Model.HoroscopeId > 0)
            {
                if (Context.Session.GetInt32("UserId") != null)
                {
                    <form method="post" action="/Comment/AddComment">
                        <input type="hidden" name="horoscopeId" value="@Model.HoroscopeId" />
                        
                        <div class="mb-3">
                            <textarea name="commentText" class="form-control" rows="3" placeholder="Bu yorum hakkında ne düşünüyorsun? Yaz..." required></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-glow rounded-pill px-4 py-2 fw-semibold">
                            Gönder 🚀
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info bg-opacity-10 text-info border-info border-opacity-25 rounded-4 d-flex align-items-center justify-content-between p-3">
                        <span>Yorum yapmak için giriş yapmalısınız.</span>
                        <a href="/Auth/Login" class="btn btn-info btn-sm text-white px-3 rounded-pill">Giriş Yap</a>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-warning bg-opacity-10 text-warning border-warning border-opacity-25 rounded-4 p-3 mb-0">
                    Bu burç için bugün henüz günlük yorum girilmediğinden dolayı yorum yapılamaz.
                </div>
            }
        </div>

        
        <div class="card card-glass p-4">
            <h4 class="fw-bold mb-4 text-white">📢 Kullanıcı Yorumları</h4>

            @if (comments != null && comments.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in comments)
                    {
                        <div class="p-3 rounded-4 bg-white bg-opacity-5 border border-white-50 border-opacity-10 shadow-sm">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-gradient">@@@item.Username</span>
                                <small class="text-muted">@item.CreatedDate.ToString("g")</small>
                            </div>
                            
                            <p class="text-white mb-0 text-wrap-fix">@item.CommentText</p>

                            @if (!string.IsNullOrEmpty(item.ReplyText))
                            {
                                <div class="mt-3 p-3 rounded-3 border-start border-warning border-3" style="background: rgba(251, 191, 36, 0.05);">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="fw-bold text-warning">👨‍💼 Yönetici Yanıtı</small>
                                        @if (item.ReplyDate.HasValue)
                                        {
                                            <small class="text-muted" style="font-size:0.75rem">@item.ReplyDate.Value.ToString("g")</small>
                                        }
                                    </div>
                                    <p class="text-secondary mb-0 small text-wrap-fix">@item.ReplyText</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div class="fs-1 mb-2">💬</div>
                    <p class="mb-0">Henüz yorum yapılmamış. İlk yorumu sen yap!</p>
                </div>
            }
        </div>
    </div>
</div>