@model AstroComment.ViewModels.ReportViewModel

@{
    ViewData["Title"] = "Raporlama & Yönetim Paneli";
}

<div class="container py-4" id="report-content">
    <div class="row mb-4 align-items-center">
        <div class="col-md-7">
            <h1 class="display-5 text-gradient fw-bold">📊 Raporlama & Yönetim</h1>
            <p class="text-secondary">AstroComment sistem durumunu, kullanıcı aktivitelerini ve raporları takip edin.</p>
        </div>
        <div class="col-md-5 text-md-end d-flex gap-2 justify-content-md-end no-print">
            <a href="/Report/ExportExcel" class="btn btn-primary btn-glow rounded-pill d-flex align-items-center gap-2 px-3 py-2 text-white">
                Excel Raporu İndir
            </a>
            <a href="/Report/ExportPdf" class="btn btn-danger btn-glow rounded-pill d-flex align-items-center gap-2 px-3 py-2 text-white" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border:none;">
                PDF Raporu İndir
            </a>
            <a href="/Admin/Comments" class="btn btn-outline-light rounded-pill px-3 py-2">
                💬 Yorum Yönetimi
            </a>
        </div>
    </div>

    
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-white p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);">
                <h6 class="text-uppercase text-white-50 fw-semibold mb-2">Toplam Yorum</h6>
                <div class="display-4 fw-bold mb-3">@Model.AdminReplyRate.TotalComments</div>
                <p class="mb-0 text-white-50">Sistemdeki toplam kullanıcı yorumu.</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-white p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <h6 class="text-uppercase text-white-50 fw-semibold mb-2">Toplam Cevap</h6>
                <div class="display-4 fw-bold mb-3">@Model.AdminReplyRate.TotalReplies</div>
                <p class="mb-0 text-white-50">Adminler tarafından yazılan cevaplar.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-white p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                <h6 class="text-uppercase text-white-50 fw-semibold mb-2">Cevaplama Oranı</h6>
                <div class="display-4 fw-bold mb-2">%@Model.AdminReplyRate.ReplyRate</div>
                <div class="progress bg-white bg-opacity-25 mb-2" style="height: 6px;">
                    <div class="progress-bar bg-white" role="progressbar" style="width: @Model.AdminReplyRate.ReplyRate%" aria-valuenow="@Model.AdminReplyRate.ReplyRate" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <p class="mb-0 text-white-50">Yorumları yanıtlama yüzdesi.</p>
            </div>
        </div>
    </div>

    
    <div class="row g-4 mb-5">
        
        <div class="col-lg-4">
            <div class="card card-glass border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-secondary">
                    <span class="me-2">🌟</span> En Çok Yorumlanan Burçlar
                </h5>
                @if (Model.MostCommentedZodiacs.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var z in Model.MostCommentedZodiacs)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                                <span class="fw-semibold text-white">@z.Name</span>
                                <span class="badge bg-primary rounded-pill px-3 py-2">@z.TotalComments Yorum</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        Henüz yorum yapılmış burç yok.
                    </div>
                }
            </div>
        </div>

        
        <div class="col-lg-4">
            <div class="card card-glass border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-secondary">
                    <span class="me-2">📅</span> Bugünün Yorum İstatistikleri
                </h5>
                @if (Model.TodayHoroscopeStats.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var ts in Model.TodayHoroscopeStats)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                                <span class="fw-semibold text-white">@ts.Name</span>
                                <span class="badge bg-success rounded-pill px-3 py-2">@ts.TodayComments Bugün</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        Bugün henüz yorum yapılmadı.
                    </div>
                }
            </div>
        </div>

        
        <div class="col-lg-4">
            <div class="card card-glass border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-secondary">
                    <span class="me-2">👑</span> En Aktif 5 Kullanıcı
                </h5>
                @if (Model.MostActiveUsers.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var u in Model.MostActiveUsers)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                                <span class="fw-semibold text-white">@@@u.Username</span>
                                <span class="badge bg-purple rounded-pill px-3 py-2 text-white" style="background-color:#764ba2">
                                    @u.TotalComments Yorum
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        Aktif kullanıcı bulunamadı.
                    </div>
                }
            </div>
        </div>
    </div>

    
    <div class="row mb-5">
        <div class="col-12">
            <div class="card card-glass border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-4 d-flex align-items-center text-secondary">
                    <span class="me-2">📈</span> Günlük Yorum Aktivitesi
                </h5>
                @if (Model.DailyActivity.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle" id="activity-table-el">
                            <thead class="table-light">
                                <tr class="text-light">
                                    <th>Tarih</th>
                                    <th>Yorum Sayısı</th>
                                    <th>Aktivite Seviyesi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var da in Model.DailyActivity)
                                {
                                    <tr>
                                        <td class="fw-semibold">@da.Date.ToShortDateString()</td>
                                        <td>@da.TotalComments</td>
                                        <td>
                                            @if (da.TotalComments > 10)
                                            {
                                                <span class="badge bg-danger rounded-pill px-3">Çok Yüksek</span>
                                            }
                                            else if (da.TotalComments > 5)
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill px-3">Yüksek</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark rounded-pill px-3">Normal</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        Aktivite kaydı bulunamadı.
                    </div>
                }
            </div>
        </div>
    </div>

    
    <div class="row">
        <div class="col-12">
            <div class="card card-glass border-0 shadow-sm rounded-4 p-4">
                <div class="row align-items-center mb-4">
                    <div class="col-md-6">
                        <h5 class="fw-bold mb-0 text-secondary">👥 Kullanıcı Yönetimi</h5>
                    </div>
                    <div class="col-md-6 no-print">
                        <form method="get" action="/Report/Index" class="row g-2">
                            <div class="col-5">
                                <select name="searchField" class="form-select text-dark bg-white">
                                    <option value="Username" selected="@(Model.SearchField == "Username")">Kullanıcı Adı</option>
                                    <option value="Email" selected="@(Model.SearchField == "Email")">E-posta</option>
                                    <option value="Role" selected="@(Model.SearchField == "Role")">Rol (Admin/User)</option>
                                </select>
                            </div>
                            <div class="col-5">
                                <input type="text" name="searchValue" class="form-control" placeholder="Aranacak değer..." value="@Model.SearchValue" />
                            </div>
                            <div class="col-2">
                                <button type="submit" class="btn btn-primary w-100">Ara</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle" id="users-table-el">
                        <thead class="table-light">
                            <tr class="text-light">
                                <th>Kullanıcı Adı</th>
                                <th>E-posta</th>
                                <th>Doğum Tarihi</th>
                                <th>Rol</th>
                                <th>Kayıt Tarihi</th>
                                <th class="text-end no-print">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SearchResults != null && Model.SearchResults.Any())
                            {
                                foreach (var user in Model.SearchResults)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-light text-primary d-flex align-items-center justify-content-center fw-bold me-2" style="width: 36px; height: 36px;">
                                                    @user.Username.Substring(0, 1).ToUpper()
                                                </div>
                                                <span class="fw-semibold text-white">@user.Username</span>
                                            </div>
                                        </td>
                                        <td>@user.Email</td>
                                        <td>@user.BirthDate.ToShortDateString()</td>
                                        <td>
                                            @if (user.Role == "Admin")
                                            {
                                                <span class="badge bg-danger">Admin</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">User</span>
                                            }
                                        </td>
                                        <td>@user.CreatedDate.ToString("g")</td>
                                        <td class="text-end no-print">
                                            <div class="d-inline-flex gap-2">
                                                
                                                <form asp-action="ChangeRole" method="post" class="d-inline">
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <select name="role" class="form-select form-select-sm d-inline-block w-auto text-dark bg-white" onchange="this.form.submit()">
                                                        @if (user.Role == "User")
                                                        {
                                                            <option value="User" selected>User yap</option>
                                                            <option value="Admin">Admin yap</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="User">User yap</option>
                                                            <option value="Admin" selected>Admin yap</option>
                                                        }
                                                    </select>
                                                </form>

                                                
                                                <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz? Tüm yorumları ve yanıtları da silinecektir.')">
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm" disabled="@(user.Username == "admin")">
                                                        Sil
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        Kullanıcı bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
