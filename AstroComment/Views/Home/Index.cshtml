@model IEnumerable<AstroComment.Models.ZodiacModel>

@{
    ViewData["Title"] = "Gökyüzü Rehberiniz";
    var emojis = new Dictionary<string, string> {
        { "Koç", "♈" }, { "Boğa", "♉" }, { "İkizler", "♊" }, { "Yengeç", "♋" },
        { "Aslan", "♌" }, { "Başak", "♍" }, { "Terazi", "♎" }, { "Akrep", "♏" },
        { "Yay", "♐" }, { "Oğlak", "♑" }, { "Kova", "♒" }, { "Balık", "♓" }
    };
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold text-gradient mb-2">✨ AstroComment Burç Rehberi</h1>
    <p class="fs-5 text-secondary max-w-2xl mx-auto">
        Yıldızların gökyüzündeki konumuna göre günlük yorumlarınızı okuyun ve etkileşimde bulunun.
    </p>
</div>

<div class="row g-4 justify-content-center">
    @foreach (var item in Model)
    {
        var emoji = emojis.ContainsKey(item.Name) ? emojis[item.Name] : "⭐";
        
        <div class="col-lg-4 col-md-6 col-sm-12">
            <div class="card card-glass border-0 rounded-4 overflow-hidden h-100 element-@item.Element.ToLower()">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-2 text-glow floating-icon">@emoji</span>
                            <h3 class="fw-bold text-white mb-0 fs-4 text-wrap-fix">@item.Name Burcu</h3>
                        </div>
                        <span class="badge rounded-pill px-3 py-1 text-uppercase text-white
                            @(item.Element == "Ateş" ? "bg-danger" : 
                              item.Element == "Toprak" ? "bg-warning" : 
                              item.Element == "Hava" ? "bg-info" : "bg-success")"
                              style="font-size: 0.75rem;">
                            @item.Element
                        </span>
                    </div>

                    <p class="text-secondary small mb-3 flex-grow-1 text-wrap-fix">
                        @item.StartDate.ToString("dd MMMM") - @item.EndDate.ToString("dd MMMM")
                    </p>

                    <div class="mt-3">
                        <a class="btn w-100 rounded-pill py-2 fw-semibold d-flex align-items-center justify-content-center gap-2"
                           style="background-color: #b19cd9; border-color: #b19cd9; color: white;"
                           asp-controller="Horoscope"
                           asp-action="Detail"
                           asp-route-id="@item.ZodiacId">
                            Yorumu Oku 🔮
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>