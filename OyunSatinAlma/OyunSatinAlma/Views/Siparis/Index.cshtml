@model List<OyunSatinAlma.MODEL.Siparis>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>📦 Sipariş Yönetimi</h2>

<div class="mb-3">

    <a href="/Siparis/ExportToPdf"
       class="btn btn-danger">
        📄 PDF İndir
    </a>

    <a href="/Siparis/ExportToExcel"
       class="btn btn-success">
        📊 Excel İndir
    </a>

</div>

<form method="get" class="mb-3">

    <select name="searchType" class="form-control w-25 d-inline">
        <option value="oyun">🎮 Oyun Adı</option>
        <option value="musteri">👤 Müşteri Adı</option>
        <option value="oyunId">🎮 Oyun ID</option>
        <option value="musteriId">👤 Müşteri ID</option>
    </select>

    <input type="text"
           name="search"
           class="form-control w-50 d-inline"
           placeholder="Ara..." />

    <button class="btn btn-primary">Ara</button>

</form>

<table class="table table-dark table-hover">

    <tr>
        <th>ID</th>
        <th>Müşteri</th>
        <th>Oyun</th>
        <th>Tarih</th>
        <th>Durum</th>
        <th>İşlem</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SiparisId</td>
            <td>@item.Musteri.AdSoyad</td>
            <td>@item.Oyun.OyunAdi</td>
            <td>@item.SiparisTarihi</td>
            <td>@item.Durum</td>

            <td>
                <a href="/Siparis/Update/@item.SiparisId"
                   class="btn btn-warning btn-sm">✏️</a>

                <a href="/Siparis/Delete/@item.SiparisId"
                   class="btn btn-danger btn-sm">🗑</a>
            </td>
        </tr>
    }

</table>