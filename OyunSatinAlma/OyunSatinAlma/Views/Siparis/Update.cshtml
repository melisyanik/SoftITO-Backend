@model OyunSatinAlma.MODEL.Siparis

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>✏️ Sipariş Güncelle</h2>

<form method="post">

    <input type="hidden" name="SiparisId" value="@Model.SiparisId" />

    <label>Müşteri</label>
    <input class="form-control mb-2"
           value="@Model.Musteri.AdSoyad"
           disabled />

    <input type="hidden" name="MusteriId" value="@Model.MusteriId" />

    <label>Oyun</label>
    <input class="form-control mb-2"
           value="@Model.Oyun.OyunAdi"
           disabled />

    <input type="hidden" name="OyunId" value="@Model.OyunId" />

    <label>Durum</label>
    <select name="Durum" class="form-control mb-3">
        <option value="Beklemede">Beklemede</option>
        <option value="Onaylandı">Onaylandı</option>
        <option value="Reddedildi">Reddedildi</option>
    </select>

    <button class="btn btn-primary w-100">Güncelle</button>

</form>