<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Oyun Evreni</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: radial-gradient(circle at top, #0b0f1a, #05070f);
            color: white;
            font-family: Arial, sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: linear-gradient(180deg, #0f172a, #0b1220);
            padding: 15px;
            transition: 0.3s;
            overflow: hidden;
            border-right: 1px solid #1f2937;
        }

        .top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .logo {
            margin: 0;
            font-weight: bold;
            color: #00ffcc;
        }

        .toggle-btn {
            background: none;
            border: none;
            color: white;
            font-size: 22px;
            cursor: pointer;
        }

            .toggle-btn:hover {
                color: #00ffcc;
            }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            text-decoration: none;
            padding: 12px;
            border-radius: 10px;
            margin-top: 8px;
            transition: 0.2s;
        }

            .sidebar a:hover {
                background: linear-gradient(135deg, #00ffcc, #00c2ff);
                color: black;
                transform: translateX(3px);
            }

        .icon {
            font-size: 18px;
            width: 30px;
            text-align: center;
        }

        /* CONTENT */
        .content {
            margin-left: 260px;
            padding: 20px;
            transition: 0.3s;
        }

        /* COLLAPSED */
        .sidebar.collapsed {
            width: 75px;
        }

            .sidebar.collapsed .text {
                display: none;
            }

            .sidebar.collapsed .logo {
                display: none;
            }

            .sidebar.collapsed a {
                justify-content: center;
            }

            .sidebar.collapsed ~ .content {
                margin-left: 95px;
            }

        .btn-game {
            background: linear-gradient(135deg, #00ffcc, #00c2ff);
            color: black;
            font-weight: bold;
            border: none;
            transition: 0.3s;
        }

            .btn-game:hover {
                transform: scale(1.05);
                box-shadow: 0 0 15px #00ffcc;
                color: black;
            }

        .card {
            background: #111827;
            border: 1px solid #1f2937;
            color: white;
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0 20px rgba(0,255,204,0.2);
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">

        <div class="top">
            <h3 class="logo">🎮 Oyunlar</h3>
            <button class="toggle-btn" onclick="toggleSidebar()">☰</button>
        </div>

        <a href="/User/Index">
            <span class="icon">🏠</span>
            <span class="text">Ana Sayfa</span>
        </a>

        @if (User.Identity.IsAuthenticated)
        {
            <a href="/User/Oyunlarim">
                <span class="icon">🎮</span>
                <span class="text">Oyunlarım</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a href="/Oyun/Index">
                    <span class="icon">👑</span>
                    <span class="text">Admin Paneli</span>
                </a>
            }

            <a href="/Auth/Logout">
                <span class="icon">🚪</span>
                <span class="text">Çıkış Yap</span>
            </a>
        }
        else
        {
            <a href="/Auth/Login">
                <span class="icon">🔑</span>
                <span class="text">Giriş Yap</span>
            </a>
            <a href="/Auth/SignUp">
                <span class="icon">📝</span>
                <span class="text">Kayıt Ol</span>
            </a>
        }
    </div>

    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("collapsed");
        }
    </script>

</body>
</html>