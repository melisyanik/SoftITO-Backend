@model List<OyunSatinAlma.MODEL.Musteri>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>👤 Müşteri Yönetimi</h2>

<a href="/Musteri/Create" class="btn btn-success mb-3">
    ➕ Yeni Müşteri
</a>

<div class="mb-3">

    <a href="/Musteri/ExportToPdf"
       class="btn btn-danger">
        📄 PDF İndir
    </a>

    <a href="/Musteri/ExportToExcel"
       class="btn btn-success">
        📊 Excel İndir
    </a>

</div>

<form method="get" class="mb-3">
    <input type="text"
           name="search"
           class="form-control w-50 d-inline"
           placeholder="Müşteri ara..." />

    <button class="btn btn-primary">Ara</button>
</form>

<table class="table table-dark table-hover">
    <tr>
        <th>ID</th>
        <th>Ad Soyad</th>
        <th>Email</th>
        <th>Telefon</th>
        <th>İşlem</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.MusteriId</td>
            <td>@item.AdSoyad</td>
            <td>@item.Email</td>
            <td>@item.Telefon</td>

            <td>
                <a href="/Musteri/Update/@item.MusteriId" class="btn btn-warning btn-sm">✏️</a>
                <a href="/Musteri/Delete/@item.MusteriId" class="btn btn-danger btn-sm">🗑</a>
            </td>
        </tr>
    }
</table>