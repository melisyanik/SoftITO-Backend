@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at top, #0b0f1a, #000000);
            font-family: 'Courier New', monospace;
            color: #00ffcc;
        }

            body::before {
                content: "";
                position: absolute;
                width: 100%;
                height: 100%;
                background-image: linear-gradient(rgba(0,255,204,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,204,0.05) 1px, transparent 1px);
                background-size: 40px 40px;
                pointer-events: none;
            }

        .login-box {
            width: 420px;
            padding: 40px;
            background: rgba(17, 24, 39, 0.95);
            border: 2px solid #00ffcc;
            border-radius: 12px;
            box-shadow: 0 0 25px #00ffcc;
            z-index: 2;
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #00ffcc;
            letter-spacing: 2px;
            text-shadow: 0 0 10px #00ffcc;
        }

        .form-control {
            background: #0b0f1a;
            border: 1px solid #00ffcc;
            color: #00ffcc;
            font-size: 16px;
            padding: 12px;
        }

            .form-control:focus {
                box-shadow: 0 0 15px #00ffcc;
                border-color: #00ffcc;
                background: #0b0f1a;
                color: #00ffcc;
            }

        .btn-login {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            background: linear-gradient(135deg, #00ffcc, #00c2ff);
            border: none;
            font-weight: bold;
            color: black;
            font-size: 16px;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: scale(1.05);
                box-shadow: 0 0 20px #00ffcc;
            }

        .error {
            margin-top: 10px;
            color: #ff4d4d;
            text-align: center;
        }

        .subtitle {
            text-align: center;
            font-size: 12px;
            opacity: 0.7;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>

    <div class="login-box">

        <h2>ADMIN PANEL</h2>
        <div class="subtitle">Retro Access System v1.0</div>

        <form method="post">

            <input name="username" class="form-control mb-3" placeholder="Kullanıcı adı" />

            <input name="password" type="password" class="form-control mb-3" placeholder="Şifre" />

            <button class="btn-login">GİRİŞ YAP</button>

            @if (ViewBag.Error != null)
            {
                <div class="error">@ViewBag.Error</div>
            }

        </form>

    </div>

</body>
</html>