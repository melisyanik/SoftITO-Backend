@model OyunSatinAlma.MODEL.Musteri
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5 pt-3">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-5 shadow-lg border-0" style="background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(10px); border-radius: 15px; border-top: 4px solid #00c2ff !important;">
                <h2 class="text-center mb-4 text-white" style="font-weight: 700; letter-spacing: 1px;">📝 YENİ HESAP OLUŞTUR</h2>
                
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" style="background: rgba(220,53,69,0.2); border: 1px solid #dc3545; color: #ffcccc;">
                        @ViewBag.Error
                    </div>
                }
                
                <form asp-action="SignUp" method="post">
                    <div class="form-group mb-3">
                        <label class="text-info mb-1 fw-bold">Ad Soyad</label>
                        <input type="text" asp-for="AdSoyad" class="form-control bg-dark text-white border-secondary" placeholder="John Doe" required style="border-radius: 8px;" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="text-info mb-1 fw-bold">E-posta Adresi</label>
                        <input type="email" asp-for="Email" class="form-control bg-dark text-white border-secondary" placeholder="ornek@mail.com" required style="border-radius: 8px;" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="text-info mb-1 fw-bold">Telefon Numarası</label>
                        <input type="text" asp-for="Telefon" class="form-control bg-dark text-white border-secondary" placeholder="0555 555 5555" style="border-radius: 8px;" />
                    </div>
                    <div class="form-group mb-4">
                        <label class="text-info mb-1 fw-bold">Şifre</label>
                        <input type="password" name="Sifre" class="form-control bg-dark text-white border-secondary" placeholder="••••••••" required style="border-radius: 8px;" />
                    </div>
                    
                    <div class="d-grid gap-3 mt-4">
                        <button type="submit" class="btn btn-game btn-lg" style="border-radius: 8px; background: linear-gradient(135deg, #00c2ff, #0055ff); color: white;">KAYIT OL 🎯</button>
                        <a asp-action="Login" class="text-center text-muted text-decoration-none mt-2" style="font-size: 0.95rem;">Zaten hesabın var mı? <span class="text-info fw-bold">Giriş Yap!</span></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
