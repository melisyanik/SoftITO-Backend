@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Admin Dashboard</h2>


<div class="row mb-4">

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h5>Posts</h5>
            <h2 id="postCount">0</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h5>Complaints</h5>
            <h2 id="complaintCount">0</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h5>Logs</h5>
            <h2 id="logCount">0</h2>
        </div>
    </div>

</div>

<hr />


<h4 class="mb-3">Latest Posts Preview</h4>

<div class="row" id="postGrid">
</div>

<style>

    .post-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        transition: .25s;
    }

        .post-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .post-img {
        height: 220px;
        object-fit: cover;
    }

    .post-body {
        padding: 12px;
    }

    .tag {
        font-size: 12px;
        color: #0d6efd;
    }

</style>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>

    $(document).ready(function(){

        loadCounts();
        loadPosts();

    });

    function loadCounts(){

        $.get("/Admin/PostList", function(data){
            $("#postCount").text(data.length);
        });

        $.get("/Admin/ComplaintList", function(data){
            $("#complaintCount").text(data.length);
        });

        $.get("/Admin/LogList", function(data){
            $("#logCount").text(data.length);
        });
    }

    function loadPosts(){

        $.get("/Admin/PostList", function(data){

            let html = "";

            data.forEach(p => {

                html += `
                <div class="col-md-4 mb-3">
                    <div class="card post-card">

                        <img src="${p.imageUrl}" class="post-img"/>

                        <div class="post-body">

                            <h5>${p.title}</h5>

                            <p class="text-muted">
                                ${p.content.substring(0,80)}...
                            </p>

                            <div class="tag">
                                #${p.tag ?? "general"}
                            </div>

                            <small class="text-muted">
                                by ${p.authorName}
                            </small>

                        </div>

                    </div>
                </div>`;
            });

            $("#postGrid").html(html);

        });

    }

</script>