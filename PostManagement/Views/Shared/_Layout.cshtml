<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>SocialMoments</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body {
            background: #f4f4f9;
            font-family: -apple-system, system-ui, Segoe UI, Roboto;
        }

        /* TOPBAR */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 999;
            background: #fff;
            border-bottom: 1px solid #e6e6e6;
        }

        .topbar-container {
            max-width: 1100px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 15px;
        }

        /* LOGO */
        .logo {
            font-weight: bold;
            font-size: 18px;
            text-decoration: none;
            color: #262626;
        }

        /* SEARCH */
        .search-box input {
            width: 220px;
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #ddd;
            background: #fafafa;
            outline: none;
        }

        /* MENU */
        .menu {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .menu-item {
            text-decoration: none;
            color: #262626;
            font-size: 14px;
            font-weight: 500;
            transition: 0.2s;
        }

            .menu-item:hover {
                color: #0d6efd;
            }

        /* AVATAR */
        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        /* POST CARD */
        .post-card {
            transition: 0.3s;
            border: none;
            border-radius: 15px;
            overflow: hidden;
        }

            .post-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            }

        .post-img {
            width: 100%;
            height: 260px;
            object-fit: cover;
        }

        .modal-content {
            border-radius: 15px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="topbar">
        <div class="topbar-container">

            <!-- LOGO -->
            <a href="/Post/Index" class="logo">
                ˙✧˖°📷 ༘ ⋆｡˚
                SocialMoments
            </a>

            <!-- SEARCH -->
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search posts..." />
            </div>

            <!-- MENU -->
            <div class="menu">
                <a href="/Post/Index" class="menu-item">🏠 Feed</a>
                    <a href="/Report/Index" class="menu-item">🚩 Report</a>
                <a href="/Admin/Login" class="menu-item">
                    🛠 Admin
                </a>
             

                <div class="avatar">U</div>
            </div>

        </div>
    </nav>

    <!-- CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>