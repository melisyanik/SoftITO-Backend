<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>SocialMoments Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial;
        }

        /* SIDEBAR */
        .sidebar {
            width: 250px;
            height: 100vh;
            background: #111827;
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            transition: 0.3s;
            overflow: hidden;
        }

            .sidebar.collapsed {
                width: 70px;
            }

        .brand {
            padding: 18px;
            font-size: 18px;
            font-weight: bold;
            border-bottom: 1px solid #1f2937;
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }

        .sidebar.collapsed .brand-text {
            display: none;
        }

        .menu {
            display: flex;
            flex-direction: column;
            margin-top: 10px;
        }

            .menu a {
                padding: 12px 20px;
                color: #cbd5e1;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
                white-space: nowrap;
            }

                .menu a:hover {
                    background: #1f2937;
                    color: white;
                }

        .sidebar.collapsed .menu-text {
            display: none;
        }

        /* CONTENT AREA */
        .page-content {
            margin-left: 250px;
            padding: 20px;
            transition: 0.3s;
        }

            .page-content.expanded {
                margin-left: 70px;
            }

        /* TOGGLE */
        .menu-toggle {
            background: #111827;
            border: none;
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            margin-bottom: 15px;
        }

            .menu-toggle .bar {
                width: 18px;
                height: 2px;
                background: white;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">

        <div class="brand">
            <span>📷</span>
            <span class="brand-text">SocialMoments</span>
        </div>

        <div class="menu">
            <a href="/Admin/Index">🏠 <span class="menu-text">Dashboard</span></a>
            <a href="/Admin/Posts">📝 <span class="menu-text">Posts</span></a>
            <a href="/Admin/Complaints">🚨 <span class="menu-text">Reports</span></a>
            <a href="/Admin/Logs">📊 <span class="menu-text">Logs</span></a>
            <a href="/Post/Index">🚪 <span class="menu-text">Logout</span></a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="page-content" id="pageContent">

        <button class="menu-toggle" id="toggleBtn">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>

        @RenderBody()

    </div>

    <script>
        $("#toggleBtn").click(function () {
            $("#sidebar").toggleClass("collapsed");
            $("#pageContent").toggleClass("expanded");
        });
    </script>

</body>
</html>